_method string_styles_holder.row_height
	## Parameters    : 
	## Returns       : Height used for rows
	## Function      : Checks if this height has been supplied,
	##                 otherwise it will use the default height as
	##                 supplied by _self.default_line_height
	_if ((l_row_height << .row_height_cache) _is _unset)
	_then
		l_row_height << .row_height_cache << _self.default_row_height
	_endif
