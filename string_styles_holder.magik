_pragma(classify_level=restricted, topic={tree_item}, usage={subclassable})
_method string_styles_holder.resolve_image(p_image_name, p_tree_or_state, _optional p_styled_string)
	## PARAMETERS    : P_IMAGE_NAME: Name of an image. This can be
	##                    a simple_vector {<bitmap_name>, [<module_name>]>,
	##                    or just simply an <image_name>. 
	##                 P_TREE_OR_STATE: If _unset, the :default
	##                    state is used, if it is a symbol, this will be used as a
	##                    state, otherwise the iterator .image_states(<image_name>)
	##                    will be send to get states. The first state for which an
	##                    image is known will be used.
	##                 [P_STYLED_STRING]: Optional styled string in
	##                    which :image, P_IMAGE_NAME is used.
	##                    In case P_IMAGE_NAME refers to an image,
	##                    an image scheme may be defined and the
	##                    image reference in P_STYLED_STRING can be
	##                    replaced with a reference for this to optimise image retrieval.
	## Returns       : 1) Name of an image that is known, this
	##                    defaults to :default, an internal image
	##                    that is always there.
	##                 2) Boolean, _true if image P_IMAGE_NAME
	##                    exists, _false if a :default has been used.
	## Function      : Check out if P_IMAGE_NAME refers to an
	##                 image_scheme, an internal image, or an
	##                 resource that exists on disk.
	##                 Return the name of a safe default image if
	##                 P_IMAGE_NAME does not exist. (This may be
	##                 slow since we do not want to cache that, it refers to
	##                 something that should be fixed.)
	##                 Use P_TREE_OR_STATE to get an image if we
	##                 have an image scheme.
	##                 Optimise for future use with P_STYLED_STRING
	##                 if possible.
	# check if a resource image is referenced
	_if simple_vector.is_class_of?(p_image_name)
	_then
		(l_image_name, l_module_name) << (_scatter p_image_name)
	_else
		# get the icon scheme
		l_image_scheme << _self.resolve_image_scheme(l_image_name << p_image_name)
	_endif
	_if (l_image_scheme _is _unset)
	_then
		# check if the name exists as a raster
		_try
			l_module_name << l_module_name.default(.module_name)
			smallworld_product.get_raster_image(l_image_name, l_module_name)
			l_image_scheme << _self.add_image_scheme(l_image_name, :default, {l_image_name, l_module_name})
			# replace the reference for the next time
			_if (p_styled_string _isnt _unset) _andif (p_image_name _isnt l_image_name)
			_then
				p_styled_string.int!replace_image_ref(p_image_name, l_image_name)
			_endif
		_when resource_not_found_warning
		      # check if the name exists as an image in window system
		      _if (!window_system!.images_data[p_image_name] _isnt _unset)
		      _then
			      # create an image scheme
			      l_image_scheme << _self.add_image_scheme(p_image_name, :default, p_image_name)
		      _else
			      # return the default image name
			      _return (:default, _false)
		      _endif
		_endtry
	_endif
	# check if we have a handler or a procedure
	_if _not l_image_scheme.is_class_of?(property_list)
	_then
		# user handler might return a image + module
		_if ((l_image_name << l_image_scheme(p_tree_or_state, l_image_name)) _is _unset)
		_then
		_elif simple_vector.is_class_of?(l_image_name)
		_then
			_return _self.resolve_image(l_image_name, p_tree_or_state)
		_else 
			_return (l_image_name, _true)
		_endif
	# get the right image for the current state
	_elif (p_tree_or_state _is _unset)
	_then
		_if ((l_image_name << l_image_scheme[:default]) _isnt _unset)
		_then
			_return (l_image_name, _true)
		_endif
	_elif symbol.is_class_of?(p_tree_or_state)
	_then
		_if ((l_image_name << l_image_scheme[p_tree_or_state]) _isnt _unset)
		_then
			_return (l_image_name, _true)
		_endif
	_else 
		_for i_state _over p_tree_or_state.image_states(p_image_name)
		_loop
			_if ((l_image_name << l_image_scheme[i_state]) _isnt _unset)
			_then
				_return (l_image_name, _true)
			_endif
		_endloop
	_endif
	# return the default image name
	>> (:default, _false)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.resolve_value(p_value, p_toggle_type, _optional p_field_name)
	## Parameters    : P_VALUE: Value for which we want an image.
	##                 P_TOGGLE_TYPE: :toggle or :radio_toggle
	##                 [P_FIELD_NAME] Index used after :toggle or
	##                    :radio_toggle in the original styled string.
	## Returns       : An image name that we can use to depict
	##                 P_VALUE, if defaults to :default.
	## Function      : Find an value_scheme for P_FIELD_NAME, if
	##                 this is not found find one for P_TOGGLE_TYPE
	##                 (which always succeeds).
	##                 Return the image name stored in the value scheme
	##                 for P_VALUE.
	_local l_value_scheme << _self.resolve_value_scheme(p_field_name)
	_if (l_value_scheme _is _unset)
	_then
		# this should always succeed
		l_value_scheme << _self.resolve_value_scheme(p_toggle_type)
	_endif
	>> l_value_scheme[p_value].default(:default)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.resolve_toggle(p_toggle, p_toggle_type, _optional p_field_name)
	## Parameters    : P_VALUE: Value that we want to map on to a
	##                    new value.
	##                 P_TOGGLE_TYPE: :toggle or :radio_toggle
	##                 [P_FIELD_NAME] Index used after :toggle or
	##                    :radio_toggle in the original styled string.
	## Returns       : An value that we can set as a new value now
	##                 that the old value is toggled. This default
	##                 to _true.
	##                 Note 
	## Function      : Find an toggle_scheme for P_FIELD_NAME, if
	##                 this is not found find one for P_TOGGLE_TYPE
	##                 (which always succeeds).
	##                 Return the mapped-to value stored in the toggle scheme
	##                 for the mapped-from value P_VALUE.
	## Note          : For :radio_toggle's, the value returned
	##                 needs to respond to .not, which will be set to all other
	##                 linked radio toggles. For :toggle's, any value is allowed,
	##                 but it should occur in a value_scheme to be displayed properly.
	_local l_toggle_scheme << _self.resolve_toggle_scheme(p_field_name)
	_if (l_toggle_scheme _is _unset)
	_then
		# this should always succeed
		l_toggle_scheme << _self.resolve_toggle_scheme(p_toggle_type)
	_endif
	>> l_toggle_scheme[p_toggle].default(_true)
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item})
_private _method string_styles_holder.int!image(p_image_name)
	## Parameters    : P_IMAGE_NAME: Name of an internal image. It can also be a
	##                    {<resource_bitmap_name>, <module_name>}.
	## Returns       : 1) A bitmap if resources are supported and
	##                    found; the name of an internal image otherwise.
	##                 2) True if a bitmap is returned, _false if
	##                    an image_name has been found.
	## Function      : 
	# ToDo: This is problem for 3.20, only use rasters only in 3.21 and higher
	# The restricition of resources being specified in a
	# simple-vector can be removed when we do not use internal
	# images anymore (maybe appart from the default one)
	_if _self.int!allow_rasters? _andif simple_vector.is_class_of?(p_image_name)
	_then
		(p_image_name, l_module_name) << (_scatter p_image_name)
		_try
			_return (smallworld_product.get_raster_image(p_image_name, l_module_name.default(.module_name)), _true)
		_when resource_not_found_warning
		_endtry
	_endif
	>> _if (!window_system!.images_data[p_image_name] _isnt _unset)
	   _then
		   >> (p_image_name, _false)
	   _else
		   >> (:default, _false)
	   _endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.stripe_colour
	## Parameters    : 
	## Returns       : Colour to be used for stripes, if _unset it
	##                 defaults to colour.called(:stripes)
	## Function      : 
	_if ((l_colour << .stripe_colour) _is _unset)
	_then
		l_colour << .stripe_colour << colour.called(:stripes)
	_endif
	>> l_colour
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.text_styles
	## Parameters    : 
	## Returns       : A new hash_table containing all self's
	##                 current text styles
	## Function      : 
	_local l_text_styles << 
		_if (.parent _isnt _unset)
		_then >> .parent.text_styles
		_else >> hash_table.new()
		_endif
	_for i_name, i_text_style _over .text_style_table.fast_keys_and_elements()
	_loop
		l_text_styles[i_name] << i_text_style
	_endloop
	>> l_text_styles
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item}, usage={internal})
_method string_styles_holder.int!highlight_style_for(p_text_style)
	## Parameters    : P_TEXT_STYLE: A new text style, one that is
	##                    acceptable for displaying trees and that could have been
	##                    created with the .add_text_style() method.
	## Returns       : A text_style, created from P_TEXT_STYLE,
	##                 that has the hightlight foreground colour.
	## Function      : Check the .highlight_text_style_table if
	##                 there is already an appriate text_style
	##                 present. If so, return that. If not, create
	##                 a new one.
	_local l_font << p_text_style.font
	_local l_overstrike? << p_text_style.overstrike?
	_local l_underline?  << p_text_style.underline?
	# next two things should currently not have been used (may be in future?)
	_local l_fixed_size? << p_text_style.fixed_size?
	_local l_multiline?  << p_text_style.multiline?
	# check if we already know this one
	_block
		_local l_text_style << .highlight_text_style_table.default_value
		_if (l_text_style _isnt _unset) _andif (l_font = l_text_style.font) _andif
		    (l_overstrike? _is l_text_style.overstrike?) _andif
		    (l_underline?  _is l_text_style.underline?)  _andif
		    (l_fixed_size? _is l_text_style.fixed_size?) _andif
		    (l_multiline?  _is l_text_style.multiline?)
		_then
			_return l_text_style
		_endif
	_endblock
	_for i_text_style _over .highlight_text_style_table.fast_elements()
	_loop
		_if (l_font = i_text_style.font) _andif
		    (l_overstrike? _is i_text_style.overstrike?) _andif
		    (l_underline?  _is i_text_style.underline?)  _andif
		    (l_fixed_size? _is i_text_style.fixed_size?) _andif
		    (l_multiline?  _is i_text_style.multiline?)
		_then
			_return i_text_style
		_endif
	_endloop
	# create a new one
	>> text_style.new_with_properties(:font, l_font,
					  :colour, colour.called(:highlight_text),
					  :overstrike?, l_overstrike?,
					  :underline?,  l_underline?,
					  :fixed_size?, l_fixed_size?,
					  :multiline?,  l_multiline?)
					  # ToDo: Test if this helps?
#					  :fill?,       _true,
#					  :fill_style, _self.highlight_fill_style)
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item})
_method string_styles_holder.selected_text_style_for(p_text_style)
	## Parameters    : P_TEXT_STYLE: A text_style that is known to self.
	## Returns       : The highlighted version (for selection) of P_TEXT_STYLE.
	## Function      : Obtain ^^^.
	>> _if ((l_value << .highlight_text_style_table[p_text_style]) _isnt _unset)
	   _then
		   >> l_value
	   _elif ((l_value << .parent) _isnt _unset)
	   _then
		   >> l_value.selected_text_style_for(p_text_style)
	   _elif ((l_value << _self.exemplar) _isnt _self)
	   _then
		   >> l_value.selected_text_style_for(p_text_style)
	   _else
		   >> p_text_style
	   _endif
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.row_height << p_new
	# Author         : GE Smallworld (Ken Korsmit)
	# Date           : Oct/2001
	#
	## Parameters    : P_NEW: Height including margins needed for a row
	##                 where a styled string is displayed using the default style.
	## Returns       : P_NEW
	## Function      : Sets self.row_height to P_NEW
	## Note          : This property should only be set when the
	##                 string_styles_holder is created, or it should be set on the
	##                 tree_item that contains it.
	.row_height_cache << p_new
	_self.changed(:height, p_new)
	>> p_new
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item}, usage={subclassable})
_method string_styles_holder.expand_scheme
	## Parameters    : 
	## Returns       : Name of icon scheme to be used for expansion
	## Function      : 
	>> _if _self.document_style?
	   _then >> :document_expand
	   _else >> :normal_expand
	   _endif
_endmethod
