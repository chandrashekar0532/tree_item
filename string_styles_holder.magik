_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.resolve_value_scheme(p_value_scheme_name)
	## Parameters    : P_VALUE_SCHEME_NAME
	## Returns       : Value scheme defined as P_VALUE_SCHEME_NAME,
	##                 _unset if there are not any.
