	##                 otherwise return the parent's one.
	_if ((l_value_scheme << .value_scheme_table[p_value_scheme_name]) _is _unset) _andif
	    ((l_parent << .parent) _isnt _unset)
	_then
		_return l_parent.resolve_value_scheme(p_value_scheme_name)
