	##                 same colour is used system wide; defaults to colour.called(:stripes). 
	.stripe_style_cache << property_list.new()
	>> .stripe_colour << p_new
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.add_image_scheme(p_name, _gather p_state_image_pairs)
	## Parameters    : P_NAME: Name of the image scheme, can be
	##                    used inside a styled string following the :image placeholder.
	##                 {P_STATE_IMAGE_PAIRS}: This can be in two formats:
	##                 1) List of <state_name>, <image>,
	##                    where <state_name> is a state as
	##                    described below, and <image> is either the name of an image
	##                    in the !window_system!, or a simple_vector containing the
	##                    bitmap resource name, and optionally the module_name.
	##                    If the module name is not specified, the :module_name
	##                    property will be used, and if that is also unspecified, the
	##                    resource will be looked up in the products.
	##                 2) A procedure or handler, which will be
	##                    passed P_TREE_OR_STATE: (see
	##                    .resolve_image()) and P_IMAGE_NAME, and should return the
	##                    name of the desired image (this can be a simple_vector
	##                    {<bitmap_name>, [<module_name>]>, or just simply an <image_name>.
	##                    In case the string_style_holder is used
	##                    inside a tree_item, one may safely assume that
	##                    P_TREE_OR_STATE is a tree, otherwise it may be any
	##                    value_holder or a state (symbol).
	## Returns       : The new image_scheme (which for the moment
	##                 is a property_list, but that might change).
	## Function      : Adds an image scheme to resolve images
	##                 depending on the state of a display tree.
	##
	## Currently allowed states are (for situation 1):
	## Leaf:               image to use when tree is a leaf
	## Expanded:           image to use when expanded
	## Collapsed:          image to use when collapsed
	## Selected:           image to use when the tree is selected
	## Default:            the default image to resort to if no
	##                     explicit image is defined for the state
	##                     the tree is in.
	## However, it is possible that subclasses of display_tree define new states.
	##
	## An example (for situation 2):
	## In the styled string: {:image, :a_bitmap, :tab, :value, :user}
	## In tree_item.new:     :image_schemes, {{:a_bitmap, handler.new(bla, :|bitmap_name_for()|)}},
	## On class bla:         _method bla.bitmap_name_for(p_display_tree)
	##                      	 >> _if (p_display_tree.key = ???)
	##	                            _then >> {:<image_name_on_disk>, :<module_name>}
	##                      	    _else >> :<image_name_in_image>
	##                      	    _endif
	##                       _endmethod
	_local l_first << p_state_image_pairs.an_element()
	_local l_scheme << _if (p_state_image_pairs.size = 1) _andif l_first.responds_to?(:|invoke()|)
			   _then >> l_first
			   _else >> property_list.new_with(_scatter p_state_image_pairs) 
			   _endif
	>> .image_scheme_table[p_name] << l_scheme
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.add_value_scheme(p_name, _gather p_value_state_pairs)
	## Parameters    : P_NAME: Name of the value scheme, can be
	##                    used inside a styled string following the :toggle/:radio_toggle placeholder.
	##                    Two backstop names have been defined for
	##                    :toggle/:radio_toggle themselves, but that is restricted/internal.
	##                 {P_VALUE_STATE_PAIRS}: A list of {<value>, <image_name>}'s.
	##                    Value is the value as it might be
	##                    retrieved with display_tree.value(), for most toggle
	##                    schemes that will be boolean's
	##                    (kleenean's), but custom schemes (incl. toggle_scheme's) may
	##                    be defined.
	## Returns       : The new value scheme (which for the moment
	##                 is a property_list, but that might change).
	## Function      : Adds a value scheme to resolve images for
	##                 toggle values depending on a certain value of a display tree.
	##
	## The default state scheme maps:
	## _true    -> :true
	## _false   -> :false
	## _maybe   -> :maybe
	>> .value_scheme_table[p_name] << property_list.new_with(_scatter p_value_state_pairs)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.add_toggle_scheme(p_name, _gather p_from_to_pairs)
	## Parameters    : P_NAME: Name of the toggle scheme, is used
	##                    when the end-user toggles a value denoted inside a styled
	##                    string following the :toggle/:radio_toggle placeholder. 
	##                    Two backstop names have been defined for
	##                    :toggle/:radio_toggle themselves, but that is restricted/internal.
	##                 {P_FROM_TO_PAIRS}: A list of {<old_value>, <new_value>}'s.
	##                    Old_value is the current value, before it
	##                    is changed to new_value. Old_value is retrieved with
	##                    display_tree.value(), and new value is set with
	##                    display_tree.value()<<. For most toggle schemes values will be boolean's
	##                    (kleenean's), but custom schemes (incl. toggle_scheme's) may
	##                    be defined. Note that for radio_toggle
	##                    scheme booleans may be the <new_value>!
	## Returns       : The new toggle scheme (which for the moment
	##                 is a property_list, but that might change).
	## Function      : Adds a toggle  scheme to change values when
	## end-            user toggles a value.
	>> .toggle_scheme_table[p_name] << property_list.new_with(_scatter p_from_to_pairs)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.add_value_formatter(p_value_name, p_formatter, _optional p_unit_display_group)
	## Parameters    : P_VALUE_NAME The identifier used
	##                    after :value in the styled string, to get an indexed value
	##                    out of the display tree. 
	##                 P_FORMATTER: Formatter to be applied to the
	##                    result of display_tree.value(P_VALUE_NAME)
	##                 [P_UNIT_DISPLAY_GROUP]: Optional unit
	##                    display that can offer alternative
	##                    formatters for P_VALUE_NAME.
	## Returns       : -
	## Function      : Store a P_FORMATTER to be applied when a
	##                 value in a styled_string gets referenced a
	##                 P_VALUE_NAME.
	.formatter_table[p_value_name] << p_formatter
	.udp_table[p_value_name] << p_unit_display_group
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.formatter(p_value_name)
	## Parameters    : P_VALUE_NAME: The identifier used
	##                    after :value in the styled string, to get an indexed value
	##                    out of the display tree. 
	## Returns       : The value formatter stored for P_VALUE_NAME, 
	##                 _unset if there is not any.
	## Function      : Checks formatters that have been defined on
	##                 _self, and if none is found the parent is checked.
	>> _if ((l_f << .formatter_table[p_value_name]) _isnt _unset)
	   _then >> l_f
	   _elif ((l_p << .parent) _isnt _unset)
	   _then >> l_p.formatter(p_value_name)
	   _endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.is_formatter_for?(p_formatter, p_value_name)
	## Parameters    : P_FORMATTER: A formatter (or procedure that
	##                    returns a string, given some input).
	##                 P_VALUE_NAME: The identifier used
	##                    after :value in the styled string, to get an indexed value
	##                    out of the display tree. Alternatively,
	##                    this may also be the name of the class
	##                    that is retrieved with :value.
	## Returns       : _true if P_FORMATTER will be used for P_VALUE_NAME,
	##                 _false otherwise.
	## Function      : 
	>> (_self.formatter(p_value_name) _is p_formatter)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.formatter(p_value_name) << p_formatter
	## Parameters    : P_VALUE_NAME: The identifier used
	##                    after :value in the styled string, to get an indexed value
	##                    out of the display tree. Alternatively,
	##                    this may also be the name of the class
	##                    that is retrieved with :value.
	##                 P_FORMATTER: A formatter (or procedure that
	##                    returns a string, given some input).
	## Returns       : P_FORMATTER
	## Function      : Stores P_FORMATTER to be used for P_VALUE_NAME,
	##                 and give a :formatter_has_been_set change notification.
	.formatter_table[p_value_name] << p_formatter
	_self.changed(:formatter_has_been_set, p_value_name, p_formatter)
	>> p_formatter
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.has_alternative_formats?(p_value_name)
	## Parameters    : P_VALUE_NAME: The identifier used
	##                    after :value in the styled string, to get an indexed value
	##                    out of the display tree. Alternatively,
	##                    this may also be the name of the class
	##                    that is retrieved with :value.
	## Returns       : _true if a unit display group has been
	##                 defined for P_VALUE_NAME *and* this
	##                 offers alternative formatters (i.e. the
	##                 group contains more than 1).
	## Function      : 
	>> _if ((l_unit_display_group << _self.unit_display_group(p_value_name)) _isnt _unset)
	   _then >> (l_unit_display_group.size > 1)
	   _else >> _false 
	   _endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_iter _method string_styles_holder.formatters_and_strings_for(p_value_name)
	## Parameters    : P_VALUE_NAME: The identifier used
	##                    after :value in the styled string, to get an indexed value
	##                    out of the display tree. Alternatively,
	##                    this may also be the name of the class
	##                    that is retrieved with :value.
	## Returns       : if a unit display group has been
	##                 defined for P_VALUE_NAME,
	##                 iterations of
	##                 1) unit formats, and
	##                 2) string names describing these
	##                 are returned
	## Function      : 
	_if ((l_unit_display_group << _self.unit_display_group(p_value_name)) _isnt _unset)
	_then
		_local (l_formats, l_strings) << l_unit_display_group.sorted_unit_formats_and_strings
		_for i_index  _over range(1, l_formats.size)
		_loop
			_loopbody (l_formats[i_index], l_strings[i_index])
		_endloop
	_endif
_endmethod
$

# ----------
# ToDo: We want to have images read as resources from a module
# ----------

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.add_image(p_name, p_colour_table, p_width, p_height, p_pixel_data)
	# Author         : GE Smallworld (Ken Korsmit)
	# Date           : Oct/2001
	#
	## Parameters    : P_NAME: Name under which this internal image
	##                    will be known in window_system.images_data.
	##                 P_COLOUR_TABLE: Collection containing simple_vectors, each:
	##                  * {<data_entry>, <colour_name>};
	##                    or containing just colour names
	##                  * <colour_name> (in which case the colour
	##                    name is used as <data_entry>);
	##                    alternatively you can also specify
	##                  * {<data_entry>, <colour_red_float>,
	##                    <colour_green_float>, <colour_blue_float>}
	##                 P_WIDTH, P_HEIGHT: Dimensions of the image
	##                 P_PIXEL_DATA: Simple_vector with P_WIDTH * P_HEIGHT
	##                    data_entries. Each <data_entry> is either 0 or a
	##                    symbol defined in P_COLOUR_TABLE.
	## Returns       : Property list as it has been passed to
	##                 window_system.images_data[P_NAME] 
	## Function      : Create a new internal image that does not
	##                 exist on disk as a resource, and that will work on all platforms
	_for i_index, i_colour _over p_colour_table.fast_keys_and_elements()
	_loop
		_if symbol.is_class_of?(l_name << l_colour_name << i_colour) _orif
		    (simple_vector.is_class_of?(i_colour) _andif
		     symbol.is_class_of?(l_colour_name << i_colour[2]) _andif
		     ((l_name << i_colour[1]) _isnt _unset))
		_then
			_if ((l_colour << colour.called(l_colour_name)) _is _unset)
			_then
				l_colour << condition.raise(:error, :string,
					write_string("Colour name ", l_colour_name, " not found"))
			_endif
			# colours in our table have been ungamma-corrected since they
			# will be gamma corrected on realisation. However, colours used
			# for internal images, will not be gamma corrected, so we have
			# to undo the un-gamma correction.
			p_colour_table[i_index] << {l_name, l_colour.red, l_colour.green, l_colour.blue}
		_endif
	_endloop
	>> window_system.images_data[p_name] << property_list.new_with(:colour_table, p_colour_table,
								       :width, p_width,
								       :height, p_height,
								       :pixel_data, p_pixel_data,
								       :|gamma_correct?|, _true)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.image(p_image_name, p_window)
	## Parameters    : P_IMAGE_NAME: Name of an internal image. It can also be a
	##                    {<resource_bitmap_name>, <module_name>}.
	##                 P_WINDOW: Canvas P_IMAGE_NAME will be
	##                    rendered on.
	## Returns       : 1) A bitmap if resources are supported and
	##                    found; the name of an internal image otherwise.
	##                 2) True if a bitmap is returned, _false if
	##                    an internal image has been found.
	## Function      : Retrieve the image named P_IMAGE_NAME, if
	##                 necessary instantiate it with P_WINDOW.
	_local (l_image, l_raster?) << _self.int!image(p_image_name)
	_if _not l_raster?
	_then
		l_image << !window_system!.image(p_window, l_image)
	_endif
	>> (l_image, l_raster?)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.image_width_and_height(p_image_name)
	## Parameters    : P_IMAGE_NAME: Name of an internal image. It can also be a
	##                    {<resource_bitmap_name>, <module_name>}.
	## Returns       : 1) The width of the image found;
	##                 2) The height of the image found.
	## Function      : 
	_local (l_image, l_raster?) << _self.int!image(p_image_name)
	>> _if l_raster?
	   _then
		   # return width/height info for raster image
		   >> l_image.size()
	   _else
		   _local l_image_data << !window_system!.images_data[l_image]
		   # is always found, there is a backstop icon
		   >> (l_image_data[:width], l_image_data[:height])
	   _endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.resolve_image_scheme(p_image_scheme_name)
	## Parameters    : P_IMAGE_SCHEME_NAME: Name of an image scheme.
	## Returns       : 
	## Function      : 
	## Methodology   :
	_if ((l_image_scheme << .image_scheme_table[p_image_scheme_name]) _is _unset) _andif
	    ((l_parent << .parent) _isnt _unset)
	_then
		_return l_parent.resolve_image_scheme(p_image_scheme_name)
	_endif
	>> l_image_scheme
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.text_width_and_height(p_text, p_text_style)
	## Parameters    : P_TEXT: A string
	##                 P_TEXT_STYLE: Normal text style
	## Returns       : 1) Width of P_TEXT displayed in P_TEXT_STYLE
	##                 2) Height of P_TEXT displayed in P_TEXT_STYLE
	## Function      : Determine dimension of P_TEXT displayed in
	##                 P_TEXT_STYLE, and compute width and height.
	_local (l_xmin, l_ymax, l_xmax, l_ymin) << p_text_style.font.string_box(p_text)
	>> l_xmax, (l_ymax - l_ymin)
_endmethod
$

