_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.text_style(p_key)
	## Parameters    : P_KEY: Name of the text_style that is wanted.
	##                 [P_SELECTED?]: If _true (false is default),
	##                 then we want a text_style that can be used
	##                 for drawing a selected item.
	## Returns       : Text style identified by P_KEY.
	## Function      : Check if we know the text style identified
	##                 by P_KEY, if so return it. If not, check if
	##                 we have a parent style holder and delegate
	##                 the call. If not, check if 
	##                 we can create it by using P_KEY as a colour
	##                 name. If not, return the default text_style.
	_local (l_value, l_found?) << .text_style_table.lookup_key(p_key)
	_if l_found?
	_then
		_return l_value
	_elif ((l_parent << .parent) _isnt _unset)
	_then
		_return l_parent.text_style(p_key)
	_elif ((l_colour << colour.called(p_key)) _isnt _unset)
	_then 
		# we are in the top, exemplar one, no parent
		# generate default styles for the know colour
		# two results are returned, the 1st in unselected, the 2nd is selected
		_return _self.add_text_style(p_key, l_colour)
	_else
		# no way to get this style, the default one is returned
		condition.raise(:warning, :string, write_string("Text style '", p_key, "' not found"))
	_endif
	>> l_value
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.add_text_style(p_name, _optional p_colour, p_underline?, p_font, p_hypertext?, p_strike_through?)
	## Parameters    : P_NAME: Name for the new text style, and
	##                    which can be used in styled strings.
	##                 [P_COLOUR]: A colour, *or* the name of a
	##                    colour *or* a text style. In the latter case, that text
	##                    style is used and all other arguments are ignored.
	##                 [P_UNDERLINE?]: Whether
	##                 [P_FONT]: A font, e.g. created with
	##                    font.new_logical(); if not specified the
	##                    'default font' will be used.
	##                 [P_HYPERTEXT?]: If _true, the
	##                    hypertext_click_notifier will be invoked it the end-user
	##                    click on text with this style; defaults
	##                    to P_UNDERLINE?.
	##                 [P_STRIKE_THROUGH?]: If _true, a line will
	##                    be drawn through the text
	##
	## Returns       : The new text style
	## Function      : Adds a text style or creates one with the
	##                 specified properties.
	##                 Once a text_styles has been defined this
	##                 way, their style-holder can be used for
	##                 retrieving styles used in styled_strings
	_local l_new, l_new_h
	_if p_colour.is_class_of?(text_style)
	_then
		l_new << .text_style_table[p_name] << p_colour
	_else 
		_if ((p_colour << _self.int!check_colour(p_colour)) _is _unset) 
		_then
			p_colour << colour.called(:foreground)
		_endif
		_if p_font _is _unset 
		_then
			p_font << _self.default_font
		_endif
		l_new << .text_style_table[p_name] << text_style.new(p_colour, p_font, p_underline?, p_strike_through?)
	_endif 
	_if (p_hypertext?.default(p_underline?) _is _true)
	_then
		.hyper_text_styles.add(l_new)
		.hyper_text_style_names.add(p_name)
	_endif
	l_new_h << .highlight_text_style_table[l_new] << _self.int!highlight_style_for(l_new)
	>> (l_new, l_new_h)
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.is_hypertext?(p_text_style)
	## Parameters    : P_TEXT_STYLE: Name of a text_style that has
	##                    been added with .add_text_style(),
	##                    or a text style itself.
	## Returns       : _true if P_TEXT_STYLE has been defined as a
	##                 hypertext styles, _false otherwise.
	## Function      : A hypertext style denotes that text
	##                 displayed in this style acts as a hypertext line,
	##                 i.e. if you click on it, it will take you elsewhere.
	##                 Textstyles can be marked as a hypertext when
	##                 they are added (.add_text_style()).
	## Note          : It is a good habit to ensure all (or only)
	##                 hypertext styles are underlined.
	>> .hyper_text_styles.includes?(p_text_style) _orif
		((l_p << .parent) _isnt _unset) _andif (l_p.is_hypertext?(p_text_style))
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.selected_row_style(p_height)
	## Parameters    : P_HEIGHT: In pixels
	## Returns       : Line_style to be used for denoting a selection, of
	##                    height P_HEIGHT and colour .selected_colour
	## Function      :
	p_height << _if (p_height _is _unset)
		    _then >> _self.row_height
		    _else >> p_height    
		    _endif.abs
	_if ((l_selected_row_style << .selected_row_style_cache[p_height]) _is _unset)
	_then
		l_selected_row_style << .selected_row_style_cache[p_height] << line_style.new(_self.selected_colour, p_height)
	_endif
	>> l_selected_row_style
_endmethod
$

