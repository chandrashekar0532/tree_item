_package sw

_pragma(classify_level=advanced, topic={tree_item})
## Contains all styles to be used for rendering styled_strings, and
## some more for rendering display_trees (which are
## styled_string containers).
##
## The following properties can only be specified during creation:
##   :style_holder       Parent style holder, used for item
##                       self's does not know.
## The following properties are supported:
##   :module_name        Used for retrieving bitmap resources, (see slot accessor)
##   :display_style:     May have three values: :normal (default), :tabular, :document
##                       :tabular: data is specified in columns. Column headings are
##                         specified. Tabs in styled_string will tab to the next
##                         column. Selections highlight the entire cell/row. 
##                       :normal: data is displayed without columns, tree like or
##                         list like. Tabs will tab to the next column, which might not
##                         exist (in case it is not displayed either). Selections
##                         highlight the text selected. 
##                       :document (not supported now, may be in future release): as :normal, but :tabs will indent.
##   :text_styles        List with <name>-<text_style> pairs, that
##                       will be passed scatterd to .add_text_style()
##                       (Alternatively, this can be lists of
##                       {<name>, <colour>(_name),
##                       [<underline?>], [font], [hypertext?], [<strike_through?>]},
##                       that will be passed to .add_text_style() as well).
##                       Here <name> is the name to be used for
##                       the text style in the styled string; the <colour> is a
##                       colour or the name of a colour (see colour.called()),
##                       <hypertext> means hypertext notifiers will be generated when
##                       the end-user click on the text. (Defaults to <underline>).
##   :class_formatters   List with {<name>, <formatter>}, where <name> is a class_name,
##                       causing the formatter to be applied when the a value following
##                       :value in the styled_string is retrieved, and the
##                       retrieved value is of the right class <name>.
##                       <formatter> is a (sub)class of string_format, or a procedure
##                       or a handler, returning a string;
##   :value_formatters   List with {<name>, <formatter>, [<unit_display_group>]}
##                       where <name> is a value_id, causing the formatter to be applied when
##                       the a value following :value in the styled_string is retrieved.
##                       <formatter> is a (sub)class of string_format, or a procedure
##                       or a handler, returning a string;
##                       <unit_display_group> is optional and used to retrieve 
##                       .sorted_unit_formats_and_strings() to
##                       get alternatives the end-user can select with a right-mouse
##                       click in the column headings.
##                       For <unit_display_group> to work, make sure <name>
##                       corresponds to the column_heading_id.
##   :image_schemes      List with {<scheme_name>, {<image_state_name>, <image>}},
##                       as might be passed to .add_image_scheme()
##   :value_schemes      List with {<scheme_name>, {<value>, <image>}},
##                       as might be passed to .add_value_scheme()
##   :toggle_schemes     List with {<scheme_name>, {<value_from>, <value_to>}},
##                       as might be passed to .add_toggle_scheme()
##   :selected_colour:   Highlight colour used for selection, defaults to colour.called(:highlight)
##   :no_focus_colour:    Colour used for selection, when the selection is depicted as 
##                       having no-focus, defaults to colour.called(:button_face)
##   :stripe_colour:     Background colour used for stripes, defaults to colour.called(:stripes)
def_slotted_exemplar(:string_styles_holder,
{
	{:parent,                     _unset},
	{:module_name,                _unset},
	{:row_height_cache,           _unset}, # ToDo
	{:text_style_table,           hash_table.new()},   # style name -> text style
	{:highlight_text_style_table, hash_table.new()},   # style name -> highlight text style
	{:hyper_text_styles,          set.new()},
	{:hyper_text_style_names,     set.new()}, # Unused, remove this after merging the patch
	{:selected_colour,            _unset}, 
	{:selected_row_style_cache,   property_list.new()},
	{:no_focus_colour,            _unset}, 
	{:no_focus_row_style_cache,   property_list.new()},
	{:stripe_colour,              _unset}, 
	{:stripe_style_cache,         property_list.new()},
	{:image_scheme_table,         hash_table.new()},
	{:formatter_table,            property_list.new()},
	{:class_formatter_table,      property_list.new()},
	{:udp_table,                  property_list.new()}, # unit display group (of formatters)
	{:value_scheme_table,         property_list.new()},
	{:toggle_scheme_table,        property_list.new()},
	{:display_style,              :normal} # :normal, :tabular, :document
})
$

_pragma(classify_level=advanced, topic={tree_item})
## Colour used for highlighting a selection; preferably this is
## not changed so the same colour is used system wide.
## Defaults to :hightlight colour from the system table.
string_styles_holder.define_slot_access(:selected_colour, :readable)
$

_pragma(classify_level=advanced, topic={tree_item})
## Colour used for drawing stripes (for alternating rows); preferably this is
## not changed so the same colour is used system wide; defaults
## to colour.called(:stripes). 
string_styles_holder.define_slot_access(:stripe_colour, :readable)
$

_pragma(classify_level=advanced, topic={tree_item})
## Name of the module that will be used when retrieving
## resources, at this moment: images. On a per image basis this
## can be overruled by specifying {<image_name>, <module_name>}
## rather than only <image_name> (in the latter case the
## module_name is used as it is set by this method)
string_styles_holder.define_slot_access(:module_name, :writable)
$

_pragma(classify_level=advanced, topic={tree_item})
## Three values are allowed:
## :normal:    Tabs move to the next cell; selection is drawn
##             as in a text-editor.
## :tabular    see: .tabular_style?
## :document   see: .document_style?
string_styles_holder.define_slot_access(:display_style, :writable)
$

_pragma(classify_level=advanced, topic={tree_item})
## Colour used for highlighting a selection; preferably this is
## not changed so the same colour is used system wide.
## Defaults to :button_face colour from the system table.
string_styles_holder.define_slot_access(:no_focus_colour, :readable)
$

