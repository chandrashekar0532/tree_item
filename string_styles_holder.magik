	## Parameters    : P_TOGGLE_SCHEME_NAME
	## Returns       : Value scheme defined as P_TOGGLE_SCHEME_NAME,
	##                 _unset if there are not any.
	## Function      : Check out if we have one defined as P_TOGGLE_SCHEME_NAME,
	##                 otherwise return the parent's one.
	_if ((l_toggle_scheme << .toggle_scheme_table[p_toggle_scheme_name]) _is _unset) _andif
	    ((l_parent << .parent) _isnt _unset)
