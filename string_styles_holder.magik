_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.new_from(_optional p_parent, p_properties)
	## Parameters    : [P_PARENT]: Parent style holder that will be
	##                    used if self's does not know a style,
	##                    scheme, etc. Defaults to the exemplar.
	##                 [P_PROPERTIES]: Property list, see .new_with()|
	## Returns       : A new instance of the class.
	## Function      : 
	_if (p_properties _is _unset)
	_then
		p_properties << property_list.new()
	_endif
	p_properties[:style_holder] << p_parent
	>> _clone.init(p_properties)
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.new_with(_gather p_properties)
	## Parameters    : P_PROPERTIES: List of key-value pairs that
	##                    will be applied to self as properties.
	## Returns       : A new instance of the class.
	## Function      : 
	## 
	## The following properties can only be specified during creation:
	##   :style_holder       Parent style holder, used for item
	##                       self's does not know.
	## The following properties are supported:
	##   :module_name        Used for retrieving bitmap resources, (see slot accessor)
	##   :display_style:     May have three values: :normal (default), :tabular, :document
	##                       :tabular: data is specified in columns. Column headings are
	##                         specified. Tabs in styled_string will tab to the next
	##                         column. Selections highlight the entire cell/row. 
	##                       :normal: data is displayed without columns, tree like or
	##                         list like. Tabs will tab to the next column, which might not
	##                         exist (in case it is not displayed either). Selections
	##                         highlight the text selected. 
	##                       :document (not supported now, may be in future release): as :normal, but :tabs will indent.
	##   :text_styles        List with <name>-<text_style> pairs, that
	##                       will be passed scatterd to .add_text_style()
	##                       (Alternatively, this can be lists of
	##                       {<name>, <colour>(_name),
	##                       [<underline?>], [font], [hypertext?], [<strike_through?>]},
	##                       that will be passed to .add_text_style() as well).
	##                       Here <name> is the name to be used for
	##                       the text style in the styled string; the <colour> is a
	##                       colour or the name of a colour (see colour.called()),
	##                       <hypertext> means hypertext notifiers will be generated when
	##                       the end-user click on the text. (Defaults to <underline>).
	##   :class_formatters   List with {<name>, <formatter>}, where <name> is a class_name,
	##                       causing the formatter to be applied when the a value following
	##                       :value in the styled_string is retrieved, and the
	##                       retrieved value is of the right class <name>.
	##                       <formatter> is a (sub)class of string_format, or a procedure
	##                       or a handler, returning a string;
	##   :value_formatters   List with {<name>, <formatter>, [<unit_display_group>]}
	##                       where <name> is a value_id, causing the formatter to be applied when
	##                       the a value following :value in the styled_string is retrieved.
	##                       <formatter> is a (sub)class of string_format, or a procedure
	##                       or a handler, returning a string;
	##                       <unit_display_group> is optional and used to retrieve 
	##                       .sorted_unit_formats_and_strings() to
	##                       get alternatives the end-user can select with a right-mouse
	##                       click in the column headings.
	##                       For <unit_display_group> to work, make sure <name>
	##                       corresponds to the column_heading_id.
	##   :image_schemes      List with {<scheme_name>, {<image_state_name>, <image>}},
	##                       as might be passed to .add_image_scheme()
	##                       Image scheme's are used to find an image for
	##                       the image_state(s) of a display tree.
	##   :value_schemes      List with {<scheme_name>, {<value>, <image>}},
	##                       as might be passed to .add_value_scheme()
	##                       Value scheme's are used to find an image for
	##                       the value of a display tree, when it is
	##                       referenced in a toggle or radio toggle.
	##   :toggle_schemes     List with {<scheme_name>, {<value_from>, <value_to>}},
	##                       as might be passed to .add_toggle_scheme()
	##                       Toggle scheme's are used to determine a new
	##                       value when a current value is 'toggled'
	##                       (most likely by the end-user clicking on a toggle).
	##                       For 'toggles' all sorts of values can be
	##                       mapped-to, as long as they exist in the value-scheme.
	##                       For 'radio-toggles' the <value_to>s must be
	##                       booleans or at least implemnet the .not method,
	##                       since <value_to>.not will be set to
	##                       associated radio-toggles.
	##   :selected_colour:   Highlight colour used for selection, defaults to colour.called(:highlight)
	##   :no_focus_colour:    Colour used for selection, when the selection is depicted as 
	##                       having no-focus, defaults to colour.called(:button_face)
	##   :stripe_colour:     Background colour used for stripes, defaults to colour.called(:stripes)
	>> _clone.init(property_list.new_with(_scatter p_properties))
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item}, usage={internal})
_private _method string_styles_holder.init(p_properties)
	## Parameters    : P_PROPERTIES: A property_list, see self's
	##                    class comments.
	## Returns       : _self.
	## Function      : Initialise self's slots; parent will be set
	##                 to :style_holder, or the exemplar if unspecified.
	.parent << _if ((l_parent << p_properties[:style_holder]) _isnt _unset)
		   _then >> l_parent
		   _else >> _self.exemplar
		   _endif
	# for the moment, share the following with parent
	#	.module_name << _unset 
	#	.display_style << :normal
	#	.selected_row_style_cache << property_list.new()
	#	.stripe_style_cache << property_list.new()
	# the following are not shared, but looked up in parent when not found
	.row_height_cache << _unset 
	.text_style_table << hash_table.new()
	.hyper_text_style_names << set.new()
	.formatter_table << property_list.new()
	.class_formatter_table << property_list.new()
	.udp_table << property_list.new()
	.image_scheme_table << hash_table.new()
	.value_scheme_table << property_list.new()
	.toggle_scheme_table << property_list.new()
	_for i_exported_property _over _self.exported_properties.fast_elements()
	_loop
		_if ((l_property << p_properties[i_exported_property]) _isnt _unset)
		_then
			_self.perform(i_exported_property.with_chevron, l_property)
		_endif
	_endloop
	>> _self
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.document_style?
	## True if things need to be displayed as a document
	## (multiple lines allowed, tabs are used for indentation
	## rather than moving to a new column, expand buttons are in grey)
	>> (.display_style _is :document)
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.tabular_style?
	## True if things need to be displayed as a table
	## (selection needs to be cell/row based; text should
	## clipped to cells)
	>> (.display_style _is :tabular)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.text_styles << p_new
	## Parameters    : P_NEW: List with <name>-<text_style> pairs, that
	##                     will be passed scatterd to .add_text_style()
	##                     (Alternatively, this can be lists of
	##                     {<name>, <colour>(_name),
	##                     [<underline?>], [font], [hypertext?], [<strike_through?>]},
	##                     that will be passed to .add_text_style() as well).
	##                     Here <name> is the name to be used for
	##                     the text style in the styled string; the <colour> is a
	##                     colour or the name of a colour (see colour.called()),
	##                     <hypertext> means hypertext notifiers will be generated when
	##                     the end-user click on the text. (Defaults to <underline>).
	## Returns       : P_NEW
	## Function      : Decache, loop over P_NEW and pass it to .add_text_style()
	.text_style_table.empty()
	.hyper_text_style_names.empty()
	# check if the user defined some text styles
	_for i_name_plus_text_style_pair _over p_new.fast_elements()
	_loop
		_self.add_text_style(_scatter i_name_plus_text_style_pair)
	_endloop
	>> p_new
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.value_formatters << p_new
	## Parameters    : P_NEW: List with {<name>, <formatter>, [<unit_display_group>]}
	##                    where <name> is a value_id, causing the formatter to be applied when
	##                    the a value following :value in the styled_string is retrieved.
	##                    <formatter> is a (sub)class of string_format, or a procedure
	##                     or a handler, returning a string;
	##                    <unit_display_group> is optional and used to retrieve 
	##                    .sorted_unit_formats_and_strings() to
	##                    get alternatives the end-user can select with a right-mouse
	##                    click in the column headings.
	##                    For <unit_display_group> to work, make sure <name>
	##                    corresponds to the column_heading_id.
	## Returns       : P_NEW
	## Function      : Decache, loop over P_NEW and pass it to .add_value_formatter()
	.formatter_table.empty()
	.udp_table.empty()
	# check if the user passed on formatter
	_for i_class_or_field_name_plus_formatter_pair _over p_new.fast_elements()
	_loop
		_self.add_value_formatter(_scatter i_class_or_field_name_plus_formatter_pair)
	_endloop
	>> p_new
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.image_schemes << p_new
	## Parameters    : P_NEW: List with {<scheme_name>, {<image_state_name>, <image>}} *or*
	##                    with {<scheme_name>, <handler_or_proc>},
	##                    as might be passed to .add_image_scheme()
	## Returns       : P_NEW
	## Function      : Purge self's current image scheme's and call
	##                 .add_image_scheme() for each scheme in P_NEW.
	##                 Image scheme's are used to find an image for
	##                 the image_state(s) of a display tree.
	## Note:         : See .add_image_scheme() for more comments!
	.image_scheme_table.empty()
	_for i_image_scheme_data _over p_new.fast_elements()
	_loop
		_self.add_image_scheme(_scatter i_image_scheme_data)
	_endloop
	>> p_new
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.value_schemes << p_new
	## Parameters    : P_NEW: List with {<scheme_name>, {<value>, <image>}},
	##                    as might be passed to .add_value_scheme()
	## Returns       : P_NEW
	## Function      : Purge self's current value scheme's and call
	##                 .add_value_scheme() for each scheme in P_NEW.
	##                 Value scheme's are used to find an image for
	##                 the value of a display tree, when it is
	##                 referenced in a toggle or radio toggle.
	.value_scheme_table.empty()
	_for i_value_scheme_data _over p_new.fast_elements()
	_loop
		_self.add_value_scheme(_scatter i_value_scheme_data)
	_endloop
	>> p_new
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.toggle_schemes << p_new
	## Parameters    : P_NEW: List with {<scheme_name>, {<value_from>, <value_to>}},
	##                    as might be passed to .add_toggle_scheme()
	## Returns       : P_NEW
	## Function      : Purge self's current toggle scheme's and call
	##                 .add_toggle_scheme() for each scheme in P_NEW.
	##                 Toggle scheme's are used to determine a new
	##                 value when a current value is 'toggled'
	##                 (most likely by the end-user clicking on a toggle).
	##                 For 'toggles' all sorts of values can be
	##                 mapped-to, as long as they exist in the value-scheme.
	##                 For 'radio-toggles' the <value_to>s must be
	##                 booleans or at least implemnet the .not method,
	##                 since <value_to>.not will be set to
	##                 associated radio-toggles.
	.toggle_scheme_table.empty()
	_for i_toggle_scheme_data _over p_new.fast_elements()
	_loop
		_self.add_toggle_scheme(_scatter i_toggle_scheme_data)
	_endloop
	>> p_new
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.default_style
	## Parameters    : 
	## Returns       : Self's default style if that has been set,
	##                 otherwise .parent's default style is returned.
	## Function      : 
	>> _if ((l_default_style << .text_style_table.default_value) _isnt _unset)
	   _then >> l_default_style
	   _else >> .parent.default_style
	   _endif
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.default_style << p_new_style
	## Parameters    : P_NEW_STYLE: A text style containing the
	##                    default that is used if not is specified.
	## Returns       : P_NEW_STYLE
	## Function      : Set a new default text style to be
	##                 used for self. This will be use when text styles are
	##                 generated for colours, and for .row_height and .char_width.
	##                 Note that, when the default style is set, .parent default
	##                 style will not be used anymore! This is done
	##                 on purpose, since the parent will have different styles
	##                 (e.g. when automatically generated from colour names).
	.row_height_cache << _unset 
	.selected_row_style_cache << property_list.new()
#	.stripe_style_cache.empty()
	_for i_name, i_text_style _over .text_style_table.keys_and_elements()
	_loop
		# remove text styles that have been generated from colours
		_if (colour.called(i_name) _is i_text_style.foreg_colour)
		_then
			.text_style_table.remove_key(i_name)
			.highlight_text_style_table.remove_key(i_name)
		_endif
	_endloop
	.highlight_text_style_table.default_value << _self.int!highlight_style_for(p_new_style)
	>> .text_style_table.default_value << p_new_style
_endmethod
$

_pragma(classify_level=basic, topic={styled_text_format}, usage={external})
_method string_styles_holder.background_colour
	# Author         : GE Smallworld (Ken Korsmit)
	# Date           : Oct/2001
	#
	## Parameters    : 
	## Returns       : 
	## Function      : 
	## Methodology   :
	>> _self.background_fill_style.colour.name
_endmethod
