_pragma(classify_level=restricted, topic={tree_item}, usage={internal})
_private _method string_styles_holder.int!check_colour(p_colour)
	## Parameters    : P_COLOUR: A colour, or the name of a colour
	##                    (a symbol)
	## Returns       : P_COLOUR or a colour generated with the name P_COLOUR.
	## Function      : 
	_if p_colour.is_class_of?(symbol)
	_then
		p_colour << colour.called(p_colour)
	_endif
	>> p_colour
_endmethod
$

_pragma(classify_level=basic, topic={styled_text_format}, usage={external})
_method string_styles_holder.background_colour << p_colour
	# Author         : GE Smallworld (Ken Korsmit)
	# Date           : Oct/2001
	#
	## Parameters    : P_COLOUR: A colour, or the name of a colour
	## Returns       : 
	## Function      : 
	## Methodology   :
	_if ((p_colour << _self.int!check_colour(p_colour)) _is _unset)
	_then
		# default to while
		_self.background_fill_style << fill_style
	_else
		_self.background_fill_style << fill_style.new(p_colour)
	_endif
	>> p_colour
_endmethod
$

