_pragma(classify_level=restricted, topic={tree_item})
_method string_styles_holder.get_comparison(p_str, p_heading_id)
	## Parameters    : P_STR: Contains the start of an compare operator;
	##                    i.e. a >, <, = or ~. The comparison operator
	##                    may also consist of 2 characters,
	##                    i.e. a <=, >=,  <> or ~=; the operator is
	##                    followed by a value to which we compare.
	##                 P_HEADING_ID: ID of the column to which this
	##                    comparison will be applied.
	## Returns       : 1) Operator found, either :|<=|, :|>=|,
	##                    :|<|, :|>|, :|=| or :|~=|
	##                 2) Value that we will compare to.
	##                 3) _true if (2) has been converted;
	##                    _false if (2) is still a string.
	## Function      : Split the operator (1) from the value (2) by
	##                 checking P_STR.
	##                 If we have unit formatter for P_HEADING_ID,
	##                 we'll try to convert (2) into that unit.
	## Conditions    : This method may raise a condition when P_STR
	##                 does not contain a valid comparison, or it
	##                 contains a string that cannot be converted to the unit 
	##                 as used by the formatter for P_HEADING_ID.
	## Note          : It is assume that the method is_comparison?
	##                 has been called and returned _true.
	_local l_converted? << _false 
	_if (p_str.size < 2)
	_then
		condition.raise(:filter_value_only_operator, :operator, p_str.subseq(1, 1))
	_endif
	_if ((l_op << :|<=|) = (l_first << p_str.subseq(1, 2))) _orif
	    ((l_op << :|>=|) = l_first) _orif
	    (("<>" = l_first) _or ((l_op << :|~=|) = l_first))
	_then
		_if (p_str.size < 3)
		_then
			condition.raise(:filter_value_only_operator, :operator, l_op)
		_endif
		p_str << p_str.subseq(3)
	_elif ((l_op << :|<|) = (l_first << p_str.subseq(1, 1))) _orif
	      ((l_op << :|>|) = l_first) _orif 
	      ((l_op << :|=|) = l_first)
	_then 
		p_str << p_str.subseq(2)
	_elif ("~" = l_first)
	_then
		l_op << :|~=|
		p_str << p_str.subseq(2)
	_else
		l_op << :|~=|
		# bad API use, this is no comparison;
		# if .is_comparison?() has been used we cannot go here.
	_endif
	# check if we have a unit-formatter for this heading
	_local l_formatter << _self.formatter(p_heading_id)
	_if l_formatter.responds_to?(:unit) _andif ((l_unit << l_formatter.unit) _isnt _unset)
	_then
		_handling error _with _proc @raise_error_as_user_error(p_condition)
					      condition.raise(:user_error, :string, p_condition.report_contents_string)
		_endproc
		_return (l_op, l_unit.unit_value_class.new_from_string(p_str, l_unit), _true)
	_endif
	>> (l_op, p_str, _false)
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item})
_method string_styles_holder.is_comparison?(p_str)
	## Returns _true if P_STR is the start of an compare operator;
	## i.e. a >, <, = or ~. The comparison operator may also
	## consist of 2 characters, i.e. a <=, >=,  <> or ~=;
	## otherwise _false is returned.
	_local l_first_el << p_str.an_element()
	>> "<>~=".includes?(l_first_el)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.truncate_text(p_text, p_text_style, p_desired_width)
	## Parameters    : P_TEXT: Text that has to be shortened
	##                 P_TEXT_STYLE: Style used to determine length
	##                 P_DESIRED_WIDTH
	## Returns       : A piece of text that is truncated and
	##                 has the style_holder.ellipses_message added.
	## Function      : Shorten P_TEXT that it fits in P_DESIRED_WIDTH.
	# may be this could be sped up by halving string, however, that
	# would be a more complex algorithm
	_local _constant c_trunc << _self.ellipses_message
	_local l_font << p_text_style.font
	# correct for the width of the ellipses
	_local l_desired_width << p_desired_width - l_font.string_width(c_trunc)
	_local l_result << ""
	_for i_char _over p_text.fast_elements()
	_loop
		# check one more character
		_if l_font.string_width(l_part << l_result + i_char) > l_desired_width
		_then
			# we always want at least the first character
			_if l_result.empty? _then l_result << l_part _endif
			_leave 
		_endif
		l_result << l_part
	_endloop
	l_result +<< c_trunc
	>> (l_result, l_font.string_width(l_result))
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.default_row_height
	## Parameters    : 
	## Returns       : Height including margins needed for a row
	##                 where a styled string is displayed using the default style.
	## Function      : Computes the above from the default_font's
	##                 cell height, adds margin (.cell_spacing_h),
	##                 rounds up to even, and caches it.
	# Rounding up to even is done cos of connect-lines for trees:
	# They are normally dotted, and it looks stupid if this is not
	# done regularly.
	_local l_row_height << _self.default_line_height + (2 * _self.cell_spacing_h)
	# used to be: _if system.window_system _is :win32 _then >> 4 _else >> 5 _endif
	_if l_row_height.odd?
	_then
		l_row_height +<< 1
	_endif
	>> l_row_height
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method string_styles_holder.default_line_height
	## Parameters    : 
	## Returns       : Height of a line of text when 
	##                 displayed using the default style.
	## Function      : Computes the above from the default_font's
	##                 cell height
	>> _self.default_font.cell_height
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.no_focus_colour
	## Colour to be used by selections that have no focus.
	## If not set, colour.called(:button_face) will be used.
	>> _if ((l_sc << .no_focus_colour) _is _unset)
	   _then >> colour.called(:button_face)
	   _else >> l_sc
	   _endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.no_focus_row_style(p_height)
	## Parameters    : P_HEIGHT: In pixels
	## Returns       : Line_style to be used for denoting a selection, of
	##                    height P_HEIGHT and colour .no_focus_colour
	## Function      :
	# check input
	_if (p_height _is _unset)
	_then
		p_height << _self.row_height
	_endif
	# check the cache, fill it when necessary
	_if ((l_no_focus_row_style << .no_focus_row_style_cache[p_height]) _is _unset)
	_then
		l_no_focus_row_style << .no_focus_row_style_cache[p_height] <<
			line_style.new(_self.no_focus_colour, p_height)
	_endif
	>> l_no_focus_row_style
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method string_styles_holder.no_focus_colour << p_new
	## Parameters    : P_NEW: A colour
	## Returns       : P_NEW
	## Function      : Decaches currently used no_focus selection line
	##                 styles, and sets the new colour to be used
	##                 for depicting a selection that has no focus.
	.no_focus_row_style_cache << property_list.new()
	>> .no_focus_colour << p_new
_endmethod
$

_pragma(classify_level=restricted)
_method string_styles_holder.int!init_standard_class_formatters()
		    
	string_styles_holder.add_class_formatter(:default, write_string)
	string_styles_holder.add_class_formatter(:float, float_format.new())
	string_styles_holder.add_class_formatter(:rational, rational_format.new())
	string_styles_holder.add_class_formatter(:integer, number_format.new())
	string_styles_holder.add_class_formatter(:bignum, write_string)
	string_styles_holder.add_class_formatter(:date,
		date_time_value_manager.new_with_properties(:environ, !date_time_environ!, :time?, _false))
	string_styles_holder.add_class_formatter(:date_time,
		date_time_value_manager.new_with_properties(:environ, !date_time_environ!, :time?, _true))

	string_styles_holder.add_class_formatter(:true,  in_place_boolean_editor)
	string_styles_holder.add_class_formatter(:maybe, in_place_boolean_editor)
	string_styles_holder.add_class_formatter(:false, in_place_boolean_editor)
_endmethod
$

message_handler.add_dependent(string_styles_holder, :initialised_language)
$
