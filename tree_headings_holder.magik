_pragma(classify_level=advanced, topic={tree_item}, usage={external})
_method tree_headings_holder.has_pick_list_for?(p_column_nr)
	## Returns _true if a column_pick_list has been specfied for
	## the column P_COLUMN_NR.
	## Returns _false otherwise.
	>> ((l_cpls << .column_pick_lists) _isnt _unset) _andif
		(l_cpls[p_column_nr] _isnt _unset)
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item}, usage={external})
_method tree_headings_holder.pick_list_for(p_column_nr)
	## Returns the column pick list for P_COLUMN_NR, if one has
	## been specified via the :column_pick_lists property. If the
	## pick list was specified as a handler, then this handler will
	## be invoked to obtain the items. 
	## If no items are found, unset is returned.
	## See sw_action for a specification of items (an item
	## can be a {<value>, <string>}.
	_if ((l_cpls << .column_pick_lists) _isnt _unset) _andif
	    ((l_cpls << l_cpls[p_column_nr]) _isnt _unset) _andif
	    handler.is_class_of?(l_cpls)
	_then
		l_cpls << l_cpls()
	_endif
	>> l_cpls
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item})
_private _method tree_headings_holder.int!group_children(p_column_index, p_heading, p_ungroup_first?)
	##
	## Group the children by the column P_COLUMN_INDEX. P_HEADING
	## is a string denoting the column heading or the item that has
	## been grouped on. P_UNGROUP_FIRST?, if _true, indicates that
	## the next first level of trees will be removed to do the
	## 'ungrouping'.
	## 

	_try _with cond
		_self.tree_manager.group_children(p_column_index, p_heading, _self.column_sort_selector(p_column_index), p_ungroup_first?)
	_when too_many_items_to_group
		.group_order << _unset
		# Fix up the menu toggle items
		_self.changed(:column_grouped_by?)
		sw_action.show_message(_self.tree_renderer.canvas, cond.report_contents_string)
		_return _false
	_endtry
	_return _true
_endmethod
$

_pragma(classify_level=restricted)
_private _method tree_headings_holder.int!check_column_orderings(l_max_cols)
	## 
	##
	need_fix? << _false
	_if ((l_column_orderings << .column_orderings) _is _unset) _orif (l_column_orderings.size <> l_max_cols)
	_then
		need_fix? << _true
	_else
		check << simple_vector.new(l_max_cols)
		# ensure that all the specified columns are in range and that all
		# are included in the list
		index << 0
		_for col _over l_column_orderings.fast_elements()
		_loop
			index +<< 1
			_if  col < 1 _or l_max_cols < col
			_then
				need_fix? << _true
				_leave
			_endif
			check[col] << _true
		_endloop
		_for col _over 1.upto(l_max_cols)
		_loop
			_if check[col] _isnt _true
			_then
				need_fix? << _true
			_endif
		_endloop
	_endif
	_if need_fix?
	_then
		l_column_orderings << .column_orderings << simple_vector.new(l_max_cols)
		_for i_column_id _over range(1, l_max_cols)
		_loop
			l_column_orderings[i_column_id] << i_column_id
		_endloop
	_endif
	>> l_column_orderings
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method tree_headings_holder.group_order << p_order
	##
	## Sets the group order if the grouping process was
	## interrupted.
	## P_ORDER is the index of the grouped column or unset if there
	## is no grouping.

	.group_order << p_order
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item})
_method tree_headings_holder.group_order
	##
	## Returns the index of the grouped column or unset if there
	## is no grouping.
	##

	>> .group_order
	
_endmethod
$

