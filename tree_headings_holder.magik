_pragma(classify_level=restricted, topic={tree_item}, usage={subclassable})
_method tree_headings_holder.column_heading_id(p_column_index)
	## Parameters    : P_COLUMN_INDEX: Index denoting the nth
	##                    column (nth being the nth position as
	##                    they were specified with column_heading_ids)
	## Returns       : ID for the P_COLUMN_INDEX-th column,
	##                 defaults to P_COLUMN_INDEX if not specified.
	## Function      : 
	>> .column_heading_ids[p_column_index]
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item}, usage={subclassable})
_method tree_headings_holder.column_headings_styled_strings << p_new_value
	## Parameters    : P_NEW_VALUE: Vector of simple_vectors
	##                   with contents that are acceptable to generate
	##                   styled_strings of. These will be used as heading texts in
	##                   the column headings. For four columns showing mail, an example could be:
	##                   {{:image, :send_priority}, {:image, :read_status}, {"From"}, "Subject"}.
	##                   Needs to have the same number of entries as there are columns.
	## Returns       : P_NEW_VALUE
	## Function      : 
	.styled_string << _unset 
	>> .column_headings_styled_strings << p_new_value
_endmethod
$

