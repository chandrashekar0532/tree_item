_pragma(classify_level=basic, topic={tree_item})
_method tree_headings_holder.column_heading_ids << p_new_value
	## Parameters    : P_NEW_VALUE: simple_vector containing IDs to
	##                   identify the columns with. If a model is known, they can
	##                   be automatically translated into
	##                   :column_headings. The translation happens
	##                    only if column_headings are not known yet.
	## Returns       : P_NEW_VALUE
	## Function      : 
	.cached_tabs << _unset
	>> .column_heading_ids << p_new_value
_endmethod
