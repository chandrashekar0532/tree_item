_pragma(classify_level=advanced, topic={tree_item})
_method tree_headings_holder.column_allow_sort? << p_new?
	## Parameters    : P_NEW?: if _true (default, unless
	##                    :cell_selection? is _false, in which case it defaults to
	##                    false), then the rows (display_trees) will be sorted when
	##                    the user clicks on the column heading; if _false, then the
	##                    user can select the column by doing this (if
	##                    :cell_selection is :false, all will be selected.)
	## Returns       : P_NEW?
	## Function      : Sets whether clicking on the column will
	##                 sort (P_NEW? is _true) or select (P_NEW? is _false)
	.styled_string << _unset
	.column_allow_sort? << p_new?
	# make sure we have headings if we set the default sort selectors
	_if (.column_headings _is _unset)
	_then
		_self.int!check_initialised()
	_endif
	_self.int!set_column_sort_selectors()
	>> p_new?
_endmethod
$

