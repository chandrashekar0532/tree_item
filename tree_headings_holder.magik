_pragma(classify_level=restricted)
_private _method tree_headings_holder.int!set_column_sort_selectors()
	## Parameters    : 
	## Returns       : 
	## Function      : Set default .column_sort_selectors, based on
	##                 the fact that display_trees are shown.
	_if .column_allow_sort?
	_then
		l_data << .column_sort_selectors << simple_vector.new(l_max_cols << .column_headings.size)
		_for i_column_id _over range(1, l_max_cols)
		_loop
			# see file sorted_collection_extras
			l_data[i_column_id] << {:display_tree, i_column_id}
		_endloop
	_else
		.column_sort_selectors << _unset 
	_endif
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item}, usage={subclassable})
_private _method tree_headings_holder.int!distribute_width_evenly(p_total_width, p_rest_width, p_col_resize_values)
	## Parameters    : P_TOTAL_WIDTH: The total width of the widget
	##                 P_REST_WIDTH: The amount of horizontal space
	##                    we have to distribute; if negative, columns will shrink.
	##                 P_COL_RESIZE_VALUES: Specifies the
	##                    proportions used for distributing P_REST_WIDTH to the
	##                    columns. If the proportion for a certain column is 0, then
	##                    it will not be resized. For the remaining columns, it is
	##                    resized relative to the sum of proportions for the current
	##                    visible columns.
	## Returns       : _true if the P_REST_WIDTH has been
	##                 distributed, _false if it has not (e.g. because
	##                 P_COL_RESIZE_VALUES are all 0, or because P_REST_WIDTH is 0)
	## Function      : Resizes the visible columns accoring to
	##                    their proportion in P_COL_RESIZE_VALUES such that the total
	##                    added width is P_REST_WIDTH.
	##                 Note that if all proportions are zero, then
	##                    nothing will happen.
	##                 If there are any spare pixels from rounding
	##                    up values, those will be added to the last visible resizable column.
	_local l_column_visibilities << .column_visibilities
	_local l_column_widths << .column_widths
	_local l_min_widths << .column_min_widths
	_local l_max_cols << l_column_widths.size
	# we have a rest width to distribute
	_local l_resize_sum << 0
	_for i_column_nr _over _self.fast_indices()
	_loop
		_if l_column_visibilities[i_column_nr]
		_then
			l_resize_sum +<< p_col_resize_values[i_column_nr]
		_endif
	_endloop
	# is there anything to resize?
	_if (p_rest_width _is 0) _orif (l_resize_sum _is 0)
	_then
		_return _false 
	_endif

	_if (p_rest_width > 0)
	_then
		# if we've gained some space, try to ensure that all columns
		# are visible first
		_local l_width_sum << _self.row_headings_width
		_for i_column_nr _over _self.fast_indices()
		_loop
			_if l_column_visibilities[i_column_nr]
			_then
				l_width_sum +<< l_column_widths[i_column_nr]
			_endif
		_endloop

		# The old width is p_total_width - p_rest_width
		_if (l_width_sum > (p_total_width - p_rest_width))
		_then
			p_rest_width -<< l_width_sum - (p_total_width - p_rest_width)
			_if p_rest_width <= 0
			_then
				# No need to do any resizing
				_return _true
			_endif
		_endif
	_endif
	
	_local l_total_extra << p_rest_width / l_resize_sum
	# distribute the resize values
	_local l_last_column, l_min_cell_w # << _self.style_holder.min_cell_w
	_for i_column_nr _over _self.fast_indices()
	_loop
		_if l_column_visibilities[i_column_nr]
		_then
			l_min_cell_w << l_min_widths[i_column_nr]
			_local l_extra_width << (l_total_extra * p_col_resize_values[i_column_nr]).rounded
			_local l_new_value << l_column_widths[i_column_nr] + l_extra_width
			# columns have a minimum width of 12 pixels
			_if (l_new_value < l_min_cell_w)
			_then
				l_extra_width << (l_new_value << l_min_cell_w) - l_column_widths[i_column_nr]
			_endif
			# set the new width
			l_column_widths[i_column_nr] << l_new_value 
			# compute what's left
			p_rest_width -<< l_extra_width
			# store last used column
			l_last_column << i_column_nr
		_endif
	_finally
		_if (l_last_column _isnt _unset)
		_then
			l_min_cell_w << l_min_widths[l_last_column]
			# add the rest width that is a left over
			_local l_new_value << l_column_widths[l_last_column] + p_rest_width
			_if (l_new_value >= l_min_cell_w)
			_then
				l_column_widths[l_last_column] << l_new_value
			_endif
		_endif
	_endloop
	# make sure changes are picked up
	_self.int!check_initialised(_true)
	>> _true 
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method tree_headings_holder.width << p_new
	## Parameters    : P_NEW: A new width that is applied to self.
	## Returns       : 
	## Function      : Depending on the values of
	##                 .distribute_spare_width (should be :always) and whether
	##                 there are .col_resize_values (how columns should resize),
	##                 the difference between self's current width and P_NEW is
	##                 distributed over the resizable columns.
	_local l_extra
	_if .width _is _unset
	_then
		.width << p_new
	_elif (l_extra << p_new - .width) _isnt 0
	_then
		_if (.distribute_spare_width _is :always) _andif (.col_resize_values _isnt _unset)
		_then
			_if _self.int!distribute_width_evenly(p_new, l_extra, .col_resize_values)
			_then 
				# the width should only be adapted *if* the total width of the
				# columns has changed; since it is equal to the total width of
				# all columns
				.width << p_new
			_endif 
		_endif
	_endif
	>> p_new
_endmethod
$

_pragma(classify_level=basic, topic={tree_item})
_method tree_headings_holder.column_widths
	## Parameters    : 
	## Returns       : Vector of widths for the columns as they
	##                 will be used for drawing.
	## Function      : 
	_self.int!check_initialised()
	>> .column_widths
_endmethod
$

_pragma(classify_level=restricted, topic={tree_item})
_method tree_headings_holder.deselect_grouping_trees(p_selection)
	## Parameters    : P_SELECTION: A display_tree_selection.
	## Returns       : 
	## Function      : Walks over P_SELECTION and deselects all the
	##                 display_trees whose function is to group other trees.
	_if (.group_order _isnt _unset)
	_then
		_local l_tree_manager << .tree_manager
		_for i_display_tree _over p_selection.elements()
		_loop
			# check if it is a top level tree, and thus a display tree used
			# for grouping;
			# alternatively we could use level, especially when we allow
			# multilevel grouping
			_if (i_display_tree.parent _is l_tree_manager)
			_then
				i_display_tree.selected? << _false 
			_endif
		_endloop
	_endif
_endmethod
$

_pragma(classify_level=restricted, usage={internal})
_method tree_headings_holder.note_change(p_who, _optional p_what, p_value)
	## Parameters    : P_WHO: Object that send out change notification
	##                 [P_WHAT]: The aspect that changed
	##                 [P_VALUE]: Optional new value for P_WHAT
	## Returns       : 
	## Function      : If P_WHAT is :height, re-calculate self's height;
	##                 if P_WHAT is :data, check what we have to do
	##                 with the sort order, on P_VALUE of :post_change
	## Methodology   :
	_if (p_what _is :height)
	_then
		# Make sure self's height get's recomputed
		.cached_tabs << _unset 
	_elif (p_what _is :data)
	_then
		_if .retain_sort_order?
		_then
			_if p_value _is :post_change
			_then
				.group_order << _unset
				_self.sort()
				_self.changed(:column_grouped_by?)			      
			_endif 
		_else
			# remove current sort and group order
			.group_order << _unset 
			_self.sort_order << _unset
			_self.changed(:column_grouped_by?)
		_endif
	_endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item})
_method tree_headings_holder.searchable_column_id
	## Parameters    : 
	## Returns       : The index of the column we want to search in,
	##                 if the user presses a key.
	## Function      : Check if we have a sort order, if so, use
	##                 the first column; otherwise takes into
	##                 account the visible column_order.
	>> _if ((l_sort_order << .sort_order) _is _unset)
	   _then
		   >> _self.first_visible_column
	   _elif (simple_vector.is_class_of?(l_sort_order))
	   _then
		   >> l_sort_order.an_element().abs
	   _else
		   >> l_sort_order.abs
	   _endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item}, usage={subclassable})
_method tree_headings_holder.column_min_width(p_column_index) << p_new
	## Parameters    : P_COLUMN_INDEX: Specifies the nth column
	##                 P_NEW: The new minimal width for the P_COLUMN_INDEX-th column
	## Returns       : P_NEW
	## Function      : Set's the minimal width the
	##                 P_COLUMN_INDEX-th column. If the current width is smaller,
	##                 it will be changed to P_NEW by calling .column_width()<<
	_if (p_column_index _is 0)
	_then
		_if (_self.row_headings_width < p_new)
		_then
			_self.row_headings_width << p_new
		_endif
		_return p_new
	_endif
	p_new << .column_min_widths[p_column_index] << p_new.max(_self.style_holder.min_cell_w)
	_if (_self.column_width(p_column_index) < p_new)
	_then
		_self.column_width(p_column_index) << p_new
	_endif
	>> p_new
_endmethod
$

