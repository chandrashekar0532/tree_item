	##                 P_EVENT: Event that has been raised
	##                 P_VALUE: _unset, or the :index in the
	##                    display_trees value if the text comes from a :value mark
	##                 P_TEXT_STYLE: Which is always :resolved_image
	##                 P_IMAGE: The image as it has been resolved
	##                 P_DX, P_DY: Relative position in P_IMAGE
	##                    (compared to P_TEXT top left being (0,0)
	.image_click_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.text_click_notifier << p_new
	## Parameters    : P_NEW: Either a symbol, being a method that
	##                    is understood by self's .The handlermodel, or
	##                    a handler (of handler class).
	## Returns       : P_NEW
	## Function      : Set a handler that is called when the
	##                 end-user clicks in a text string (or
	##                 any other object that has been converted to one)
	##                 inside the styled string.
	##                 When invoked, the handler gets passed seven arguments:
	##                 P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised
	##                 P_VALUE: _unset, or the :index in the
	##                    display_trees value if the text comes from a :value mark
	##                 P_TEXT_STYLE: Text style with what
	##                    P_TEXT has been drawn.
	##                 P_TEXT: The text as it is in the parsed styled string
	##                 P_DX, P_DY: Relative position in P_TEXT
	##                    (compared to P_TEXT top left being (0,0)
	.text_click_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.radio_toggle_notifier << p_new
	## Parameters    : P_NEW: Either a symbol, being a method that
	##                    is understood by self's .model, or
	##                    a handler (of handler class).
	## Returns       : P_NEW
	## Function      : Set a handler that is called when the
	##                 end-user clicks on an image (or
	##                 any other object that has been converted to one)
	##                 inside the styled string.
	##                 This image is used such that the user can
	##                 *radio_toggle* it.
	##                 When invoked, the handler gets passed seven arguments:
	##                 P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised
	##                 P_VALUE: _unset, or the :index in the
	##                    display_trees value if the text comes from a :value mark
	##                 P_TEXT_STYLE: Which is always :resolved_image
	##                 P_IMAGE: The image as it has been resolved
	##                 P_DX, P_DY: Relative position in P_IMAGE
	##                    (compared to P_TEXT top left being (0,0)
	.radio_toggle_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.handle_mouse_button_event(p_event)
	## Parameters    : P_EVENT: Mouse event that has been raised,
	##                    it must have its category = :button.
	## Returns       : True if the event has been handled, false if
	##                 it still needs handling
	## Function      : Handle the mouse button event P_EVENT
	## Note:           You can only catch middle_mouse_notifier if win32_window_system.mouse_buttons _is 3

	_local l_id << p_event.id
	_local (l_row, l_in_col_headings?, l_row_index, l_remainder) << .window.row_at(p_event.y)
	# after correction, do the actual processing
	_if (l_id _is :right)
	_then
		_if (p_event.func _is :press)
		_then
			_self.activate_right_mouse_menu(l_row, l_row_index, p_event, l_in_col_headings?)
		_endif
	_elif l_in_col_headings? 
	_then
		(l_renderer, l_remainder) << .window.int!col_renderer_at(l_remainder)
		_local (l_handled?, l_action, _gather l_data) << l_renderer.handle_click(p_event.x, l_remainder, p_event, _self)
		_local l_notifier << _self.notifier_for_action[l_action]
		_if (l_notifier _isnt _unset)
		_then
			l_handled? << l_handled? _orif (_self.notify(l_notifier, l_row, l_row_index, p_event, _scatter l_data) _is _true)
		_endif
	_elif (l_row _is _unset)
	_then
		# tried to select something that isnt there
		# ToDo: Check if we are extending the selection
	_elif (l_id _is :left)
	_then
		_local l_func << p_event.func
		_if (l_func _is :press)
		_then
			_try
				_self.stop_edit()
			_when cancel_selection_change
				_return _true
			_endtry
		_endif
		_if (l_func _is :press) _orif
		    (l_func _is :double_press) _orif
		    (l_func _is :release)
		_then
			# check if user is expanding/collapsing, etc.
			_local l_tree_renderer << _self.tree_renderer
			# set the display tree
			l_tree_renderer.value_holder << l_row
			_local (l_handled?, l_action, _gather l_data) << l_tree_renderer.handle_click(p_event.x, l_remainder, p_event, _self)
			_local l_notifier << _self.notifier_for_action[l_action]
			_if (l_notifier _isnt _unset)
			_then
				l_handled? << l_handled? _orif (_self.notify(l_notifier, l_row, l_row_index, p_event, _scatter l_data) _is _true)
			_endif
			_if (l_handled? _is _true)
			_then
				# ToDo: Improve this: we only need to redraw some rows
				_self.damaged(_unset)
			_endif
		_elif (l_func _is :double_release)
		_then
			_self.notify(:double_click_notifier, l_row, l_row_index, p_event, _self.selection)
		_endif
	_elif (l_id _is :middle)
	_then
		_self.notify(:middle_mouse_notifier, l_row, l_row_index, p_event)
	_endif
	_return _true 
_endmethod
$

_pragma(classify_level=advanced)
_method tree_agent.editors
	## Parameters    : - 
	## Returns       : Property list containing <value_id>s as
	##                 keys, and instantiated in-place-editors as values.
	## Function      : This provides editors to the
	##                 .default_editor_required() function.
	_if ((l_eds << .editors) _is _unset)
	_then
		l_eds << .editors << property_list.new()
	_endif
	>> l_eds
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.stop_edit(_optional p_allow_recovery?, p_raise_condition?, destroying?)
	##
	## If we're editing, stop the edit and hide the edit controls
	##
	## If P_ALLOW_RECOVERY? is _true (default) then - if error
	## conditions are raised during the stopping of the actually
	## editor - the editing will *not* stop. However, if this is
	## set to _false - e.g. when the whole dialog is closed -
	## editing really should stop and no recovery may take place.
	##
	## This is very useful if an editor does not want to accept a
	## certain value. Editing should continue rather than that the
	## end-user gets focused on something else.
	##
	## If an user-error occurs - currently edited value is not ok -
	## and P_ALLOW_RECOVERY?, than a alert is shown with that error
	## in a message, and the condition :cancel_selection_change is
	## raised. P_ALLOW_RECOVERY? defaults to P_ALLOW_RECOVERY?.
	##
	_if ((l_em << .edit_manager) _isnt _unset) _andif l_em.editing?
	_then
		_local (l_vh, l_ri, l_vi) << (l_em.value_holder, l_em.value_info, l_em.value_id)
		_if (l_stopped? << l_em.stop_edit(p_allow_recovery?, p_raise_condition?, destroying?))
		_then
			# notify
			_self.notify(:edit_stop_notifier, l_vh, l_ri, l_vi, l_em)
		_endif
	   _endif
	>> l_stopped?.default(_false) 
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.default_editor_required(p_tree, p_row_index, p_value_id)
	## Parameters    : P_TREE: Tree that is selected
	##                 P_ROW_INDEX: Row on which P_TREE appears
	##                 P_VALUE_ID: Id of the value in P_TREE for
	##                    which an editor is required.
	## Returns       : An editor that is suitable for P_VALUE_ID,
	##                 or _unset if none can be found.
	## Function      : Check editors whether it contains P_VALUE_ID.
	>> _self.editors[p_value_id]
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.int!caret_pos(p_text, p_font, p_dx)
	##
	## Compute which character of P_TEXT occupies the pixel given
	## by the horizontal offset P_DX when P_TEXT is displayed using
	## P_FONT.
	##
	_local l_caret_pos << 0
	_local l_checked_width << p_dx
	_for i_char _over p_text.fast_elements()
	_loop
		# check next character
		_local l_char_width << p_font.string_width(i_char)
		_if (l_char_width _div 2) > l_checked_width
		_then
			_leave
		_endif 
		l_checked_width -<< l_char_width
		l_caret_pos +<< 1
	_endloop
	>> l_caret_pos
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.value_changed_notifier << p_new
	## P_NEW is a handler that is called when the
	## end-user has changed a value in an in-place editor and this
	## is about to be set to the value-holder (display_tree).
	## When invoked, the handler gets passed five arguments:
	## P_TREE: Display tree whose value is changed
	## P_VALUE_ID: Id following :value in the styled string,
	##    identifying the value that we want to edit.
	## P_NEW_VALUE: The new value that we are about to set.
	## P_UNDO_VALUE: Value that used to be there at the start of
	##    this edit action.
	## P_EDITOR: The editor that made the change
	.value_changed_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.handle_value_release_click(p_tree, p_row_index, p_event, p_value, p_text_style, p_text, p_dx, p_dy, p_width, p_height)
	## Parameters    : P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised
	##                 P_VALUE: _unset, or the :index in the
	##                    display_trees value if the text comes from a :value mark
	##                 P_TEXT_STYLE: Text styled used for depicting
	##                    a text, or :resolved_image in case P_TEXT concerned an image.
	##                 P_TEXT: The text as it is retrieved from P_TREE.value(P_VALUE)
	##                 P_DX, P_DY: Relative position in P_TEXT
	##                    (compared to P_TEXT top left being (0,0)
	##                 P_WIDTH, P_HEIGHT: Of the item that has been
	##                    clicked on.
	## Returns       : - 
	## Function      :
	# check if we have a way to obtain an editor
	_if ((l_editor_req << _self.editor_required_notifier) _is _unset)
	_then
		_return
	_endif
	# check if we are will immediately start editing
	_if _not .edit_on_click?
	_then
		_if (.int!override_data _is _unset) _orif (.int!override_data.an_element() _isnt :selection_click_with_no_change)
		_then
			# the user changed the selection with this click, so we do not
			# want to start editing now. If the user want to start editing,
			# (s)he should click *in* the selection.
			_return 
		_endif
	_endif
	# check if we need to leave the current edit session
	# if we are still editing (while have gained focus already) and
	# we should not (since we are not 'always' editing) then we
	# just had a problem leaving the current editing session.
	# In that case, do not start another one!
	_if _self.editing? _andif _not (_self.edit_always_on?)
	_then
		_return 
	_endif
	# invoke it
	_local l_editor << l_editor_req.invoke(p_tree, p_row_index, p_value, _self)
	_if (l_editor _isnt _unset)
	_then
		# check if the value we're editing is an image
		_local l_val_left << (p_event.x - p_dx)
		_local l_val_right << (l_val_left + p_width)
		_local l_click_pos << _if (p_text_style _isnt :resolved_image)
				      _then
					      >> _self.int!caret_pos(p_text, p_text_style.font, p_dx)
				      _else
					      p_text_style << _self.style_holder.default_style
					      >> -1
				      _endif 
		# get cell dimensions # FIXME: does not work for merged cells
		_local (l_left, l_top, l_right, l_bottom, l_align) << .window.cell_info_at(p_event.x, p_event.y)
		(l_found?, l_left, l_top, l_right, l_bottom) << .window.check_bounds(l_left, l_top, l_right, l_bottom)
		_if (_not l_found?) _then _return _endif 
		# user clicked on the value directly, so set focus
		_local l_focus? << _true 
		_self.start_edit(p_tree, p_row_index, p_value, l_editor, p_text_style, l_click_pos,
				 l_left, l_top, l_right, l_bottom, l_val_left, l_val_right, l_align, l_focus?)
	_endif
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.editor_required_notifier << p_new
	## P_NEW is a handler that is called when the
	## end-user has pressed :f2 or clicked on a :value.
	## This should return an instantiated editor with its
	## properties set fine to start editing P_VALUE_ID fo P_TREE.
	## If nothing is returned, the value will not be edited.
	## When invoked, the handler gets passed four arguments:
	## P_TREE: Display tree that has been clicked on (unset
	##    if it is in the column headings or below
	##    the last one)
	## P_ROW_INDEX: Index in the list of visible
	##    display trees.
	## P_VALUE_ID: Id following :value in the styled string,
	##    identifying the value that we want to edit.
	## P_AGENT: Tree agent (self) that should be made the agent of
	## any editor that will be returned by this notifier.
	.editor_required_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.edit_manager
	##
	## Returns the in place edit manager
	##
	## Note that this should only be called once the .window slot
	## has been initialised.
	## 
	_if ((l_em << .edit_manager) _is _unset)
	_then
		l_em << .edit_manager << in_place_edit_manager.new(_self.window)
	_endif
	>> l_em
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.handle_release_click(p_tree, p_row_index, p_event)
	##
	## An action to start editing an editable value in the vicinity
	## of a click (if there is one).
	##
	## Parameters    : P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised
	##
	
	# we should not do a toggle or the like, and have exactly one
	_if (p_event.modmask _isnt 0) _orif (_not _self.selection.precisely_one_selected?)
	_then
		_return
	_endif
	# check if we have a way to obtain an editor, and if we to edit on click
	_if ((l_editor_req << _self.editor_required_notifier) _is _unset) _orif _not _self.edit_on_click?
	_then
		_return
	_endif
	# check if we need to leave the current edit session
	# if we are still editing (while have gained focus already) and
	# we should not (since we are not 'always' editing) then we
	# just had a problem leaving the current editing session.
	# In that case, do not start another one!
	_if _self.editing? _andif _not (_self.edit_always_on?)
	_then
		_return 
	_endif
	# only when user did not click *on* value, but before or after
	_local (l_found?, l_value_id, l_editor, l_text_style, l_val_left, l_val_right, l_col, l_end_col, l_edit_at_end?) <<
		.window.int!editable_value_at(p_event.x, p_event.y, p_tree, p_row_index, l_editor_req)
	_if l_found?
	_then
		_local l_click_pos << _if l_edit_at_end? _then >> 1000 _else >> -1 _endif
		# get cell dimensions
		_local (l_left, l_top, l_right, l_bottom, l_align) << .window.cell_info(p_tree, p_row_index, l_col, l_end_col)
		# normally, if a user clicked in a cell, the dimensions would
		# be ok; however check, just in case only a few pixels are visible
		(l_found?, l_left, l_top, l_right, l_bottom) << .window.check_bounds(l_left, l_top, l_right, l_bottom)
		_if (_not l_found?) _then _return _endif 
		# user clicked next to value directly, so only set focus if we
		# are not in an always edit mode (in which case, starting to
		# type has the same effect whether or not the first text item
		# has focus: it will whipe out what is there)
		_local l_focus? << (_not _self.edit_always_on?)
		_self.start_edit(p_tree, p_row_index, l_value_id, l_editor, l_text_style, l_click_pos,
				 l_left, l_top, l_right, l_bottom, l_val_left, l_val_right, l_align, l_focus?)
	_endif
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.edit_stop_notifier << p_new
	## P_NEW is a handler that is called when the
	## end-user stops editing a value, just after the edit
	## controls are hidden.
	## (There may be a programmatic cause to this).
	## When invoked, the handler gets passed five arguments:
	## P_TREE: Display tree that has been clicked on (unset
	##    if it is in the column headings or below
	##    the last one)
	## P_ROW_INDEX: Index in the list of visible
	##    display trees.
	## P_VALUE_ID: Id following :value in the styled string,
	##    identifying the value that we want to edit.
	## P_EDITOR: The editor that will be used.
	## P_EDIT_MANAGER: The manager that takes care of the resources.
	.edit_stop_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=advanced)
_method tree_agent.editing?
	##
	## Return _true if an in-place editor is shown, editing a value;
	## _false otherwise.
	## 
	>> _if ((l_em << .edit_manager) _isnt _unset)
	   _then >> l_em.editing?
	   _else >> _false 
	   _endif
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.start_edit(p_tree, p_row_index, p_value_id, p_editor, p_text_style, p_click_pos,
			      p_left, p_top, p_right, p_bottom, p_val_left, p_val_right, p_align, p_focus?)
	## Parameters    : P_TREE: Display tree that will be edited.
	##                 P_ROW_INDEX: Row on which is displayed.
	##                 P_VALUE_ID: Value of P_TREE that will be edited.
	##                 P_EDITOR: is an instantiated in-place editor
	##                    subclass. Its properties should have been
	##                    set ok before calling this function.
	##                 P_TEXT_STYLE: Text style to be used
	##                 P_CLICK_POS: is the character position at
	##                    which the user clicked in the text. -1
	##                    denotes that all text should be selected.
	##                 P_LEFT, P_TOP, P_RIGHT, P_BOTTOM: Bounds of
	##                    cell in which editing should take place.
	##                 P_VAL_LEFT and P_VAL_RIGHT give the positions 
	##                    of the left and right edge of the value.
	##                 P_ALIGN: Align used to draw the current value,
	##                    i.e. :left, :centre or :right.
	##                 P_FOCUS?: Whether or not the in-place-editor
	##                    should get focus or not.
	## Returns       : 
	## Function      : Build the GUI to edit the value ID P_VALUE_ID 
	##                 provided by the display_tree P_TREE on row P_ROW_INDEX,
	##                 and starting editing it using P_EDITOR.
	# check if we are already editing with this info
	_local l_em << _self.edit_manager
	_if l_em.editing?(p_tree, p_value_id)
	_then
		# set focus if necessary
		_if p_focus?
		_then
			l_em.set_focus(p_click_pos)
		_endif
		_return 
	_endif
	# provide all date to edit manager and display controls
	l_em.start_edit(p_tree, p_row_index, p_value_id, p_editor, p_text_style, p_click_pos,
			p_left, p_top, p_right, p_bottom, p_val_left, p_val_right, p_align, p_focus?)
	# notify
	_self.notify(:edit_start_notifier, p_tree, p_row_index, p_value_id, p_editor, l_em)
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.default_handle_edit(p_tree, p_start_row, p_keyb_event, p_selection)
	##
	## Activate the edit GUI for the next editable value in the row;
	## we'll look for the next editable value in P_TREE.
	## (We have remembered the previous one we've edited).
	##
	## P_TREE is the display tree for the current row.
	## P_START_ROW is the row index.
	## P_KEYB_EVENT is the keyboard event which triggered this action.
	## P_SELECTION is the current selection.
	##
	# check if we have a way to obtain an editor
	_if ((l_editor_req << _self.editor_required_notifier) _is _unset)
	_then
		_return _false 
	_endif
	# check the selection
	_local (l_found?, l_value_id, l_editor, l_text_style, l_val_left, l_val_right, l_column_no, l_column_end_no) <<
		.window.int!next_editable_value(p_tree, p_start_row, .last_edited_value, l_editor_req)
	_if l_found?
	_then
		
		_local  (l_left, l_top, l_right, l_bottom, l_align) << .window.cell_info(p_tree, p_start_row, l_column_no, l_column_end_no)
		(l_found?, l_left, l_top, l_right, l_bottom) << .window.check_bounds(l_left, l_top, l_right, l_bottom)
		_if (_not l_found?) _then _return _false _endif 
		# edit at end
		_local l_caret_pos << -1
		# user clicked next to value directly, so only set focus if we
		# are not in an always edit mode (in which case, starting to
		# type has the same effect whether or not the first text item
		# has focus: it will whipe out what is there)
		_local l_focus? << (_not _self.edit_always_on?)
		_self.start_edit(p_tree, p_start_row, l_value_id, l_editor, l_text_style, l_caret_pos,
				 l_left, l_top, l_right, l_bottom, l_val_left, l_val_right, l_align, l_focus?)
		.last_edited_value << l_value_id
	_endif
	>> l_found?
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.edit_start_notifier << p_new
	## P_NEW is a handler that is called when the
	## end-user starts editing a value, just before the edit
	## controls are shown.
	## When invoked, the handler gets passed five arguments:
	## P_TREE: Display tree that has been clicked on (unset
	##    if it is in the column headings or below
	##    the last one)
	## P_ROW_INDEX: Index in the list of visible
	##    display trees.
	## P_VALUE_ID: Id following :value in the styled string,
	##    identifying the value that we want to edit.
	## P_EDITOR: The editor that will be used.
	## P_EDIT_MANAGER: The manager that takes care of the resources.
	.edit_start_notifier << handler.check_type(p_new, .model)
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.int!edit_data
	##
	## Returns a property_list for holding editor related data
	## 
	>> .int!inline_editor_data
_endmethod
$

_pragma(classify_level=advanced)
_method tree_agent.editors << p_new
	## Parameters    : P_NEW: Collection containing definitions to
	##                    create in-place-editors, in the format:
	##                 <Value_id>: id following :value in styled-string.
	##                 <Editor_class>: Exemplar to send .new(<agent>, <key-vals>) method to.
	##                 <Key-value> pairs: List of key-vals that will
	##                    be passed to the new method.
	## Returns       : P_NEW
	## Function      : Set editors to be used by .default_editor_required() function.
	##                 This can be passed as :editors, P_NEW to the
	##                 tree-item.new methods.
	_local l_evs << _self.editors.empty()
	_for i_editor_for_value_data _over p_new.fast_elements()
	_loop
		_local (l_value_id, l_editor_class, _gather p_data) << (_scatter i_editor_for_value_data)
		l_evs[l_value_id] << l_editor_class.new(_self, _scatter p_data)
	_endloop
	>> p_new
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.set_default_cursor()
	## Parameters    : -
	## Returns       : -
	## Function      : Set self's window cursor to self's window's
	##                 parent cursor, so it will correctly display
	##                 the state of the model again.
	## Methodology   : This is done by settings self's cursor to
	##                 unset, such that it no longer overrides the
	##                 cursor set on the window's parent (e.g. a frame)
	.window.cursor << _unset 
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_private _method tree_agent.int!locate_drag_handlers(p_event, p_default_mouse)
	## Parameters    : P_EVENT: Event that needs to be analysed for dragging:
	##                    Is it a valid drag?
	##                    Is it in one of self's drag destinations?
	##                 P_DEFAULT_MOUSE: The default mouse action
	##                    for the event. If not provided, this will
	##                    be a :link action if we press Alt or several modifiers;
	##                    it will be :copy if we press Ctrl, and
	##                    it default to the :move action.
	##                    The allow-drag notifier should return
	##                    _true for valid dragging, and optionally may override this
	##                    default mouse action. If _true has been returned,
	##                    P_DEFAULT_MOUSE will be used to set self's mouse cursor,
	##                    thus providing feedback to the end-user about the result of
	##                    his/her drag operation.
	## Returns       : 1) Found notifiers, this is a vector of the
	##                    allow-drag and release-drag notifiers.
	##                 2) Vector with arguments for notifiers
	## Function      :
	# check if there is anything to drag
	_if (l_sel << _self.selection).empty? _then _return _endif
	# check if we are allowed to drag the selection onto this tree
	_local l_first_time? << (p_default_mouse _is _unset)
	# Always set the 'default mouse' to be a symbol based on the
	# latest state of the modifier keys
	p_default_mouse << _if (p_event.modmask >= 3)
			   _then >> :link
			   _elif (p_event.modmask = 2)
			   _then >> :copy
			   _else >> :move
			   _endif
	# check if we are inside our own bounds, or we have to check our drag destinations
	_local l_window << _self.window
	_local l_x << p_event.x - l_window.horizontal_position
	_local l_y << p_event.y - l_window.vertical_position
	_if (l_x.in_range?(0, l_window.width) _andif l_y.in_range?(0, l_window.height))
	_then
		# check if we have dragged onto a tree
		_local (l_tree, l_in_col_headings?, l_row_index, l_remainder) << .window.row_at(p_event.y)
		_if (l_tree _isnt _unset) _andif ((l_allowh << _self.allow_dragging_notifier) _isnt _unset) _andif
		    ((l_releaseh << _self.release_dragging_notifier) _isnt _unset)
		_then
			_return {l_allowh, l_releaseh}, {l_tree, l_row_index, _self.column_at(p_event.x), l_sel, p_event, p_default_mouse, l_first_time?}
		_endif
	_elif (.int!drag_to_agents _isnt _unset)
	_then
		(l_x, l_y) << l_window.actual.translate_coords(l_x, l_y)
		_for i_agent, i_notifiers _over .int!drag_to_agents.fast_keys_and_elements()
		_loop
			_local l_dwindow << i_agent.window
			_if _not l_dwindow.realised? _then _continue _endif
			# get position of destination
			_local (l_dx, l_dy) << l_dwindow.actual.translate_coords(0, 0)
			(l_dx, l_dy) << (l_x - l_dx, l_y - l_dy)
			_if l_dx.in_range?(0, l_dwindow.width) _andif l_dy.in_range?(0, l_dwindow.height)
			_then
				p_event.x << l_dx +<< l_dwindow.horizontal_position
				p_event.y << l_dy +<< l_dwindow.vertical_position
				_local (l_tree, l_in_col_headings?, l_row_index, l_remainder) << l_dwindow.row_at(l_dy)
				_return i_notifiers, {l_window, l_tree, l_row_index, i_agent.column_at(l_dx), l_sel, p_event, p_default_mouse, l_first_time?}
			_endif
		_endloop
	_endif 
_endmethod
$

_pragma(classify_level=advanced, usage={subclassable})
_method tree_agent.int!add_drag_to_agent(p_agent, p_release_drag_notifier, p_allow_drag_notifier)
	## Parameters    : P_AGENT: Another agent whose window is a
	##                    valid destination for dragging that start from me.
	##                 P_RELEASE_DRAG_NOTIFIER: Called when a
	##                    selection has been dragged onto P_AGENT's
	##                    window and is released, should implement
	##                    the drag's action.
	##                 P_ALLOW_DRAG_NOTIFIER: Called when a
	##                    selection is being dragged onto P_AGENT's window,
	##                    should return whether that is allowed or not.
	## Returns       : - 
	## Function      : Store drag destination; if the current
	##                 drag-notifier is :notify_default_select_dragging(),
	##                 (which allows selecting by dragging)
	##                 this will be replaced by :notify_default_dragging(),
	##                 which allows dragging of the selection.
	_if ((l_drag_tos << .int!drag_to_agents) _is _unset)
	_then
		l_drag_tos << .int!drag_to_agents << weak_hash_table.new()
		_if .drag_notifier.sys!slot(:method_and_args) _is :|notify_default_select_dragging()|
		_then
			.drag_notifier << handler.new(_self, :|notify_default_dragging()|)
		_endif
	_endif
	# add...
	l_drag_tos[p_agent] << {p_allow_drag_notifier, p_release_drag_notifier}
_endmethod
$

_pragma(classify_level=advanced, usage={subclassable})
_method tree_agent.register_drag_source(p_agent, p_release_drag_notifier, _optional p_allow_drag_notifier)
	## Parameters    : P_AGENT: Another tree-agent whose window is a
	##                    valid source to start dragging from to myself.
	##                 P_RELEASE_DRAG_NOTIFIER: Notifier that is called
	##                 [P_ALLOW_DRAG_NOTIFIER]: Default to always allowing.
	## Returns       : -
	## Function      : Registers P_AGENT's window as a valid control to
	##                 start dragging from to _self. If dragging
	##                 from P_AGENT's window onto _self is taking place,
	##                 P_ALLOW_DRAG_NOTIFIER is called to ask if
	##                 this is a valid drag position. When the dragging ends,
	##                 P_RELEASE_DRAG_NOTIFIER is called to denote
	##                 the end of the drag operation and allows the API to
	##                 carry out the underlying behaviour.
	## Use:            The allow-drag and release-drag notifiers
	##                 are called with the following parameters:
	##                 P_SOURCE: Tree-item (window of agent) that
	##                    we are currently dragging on.
	##                 P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_COL_INDEX: Index in the list of columns.
	##                 P_SELECTION: Display tree selection which is
	##                    the current set of selected trees, i.e. the ones that are
	##                    being dragged onto P_TREE.
	##                 P_EVENT: Event that has been raised.
	##                 P_DEFAULT_MOUSE: Depending on modmask of P_EVENT:
	##                    When just Ctrl or Shft are pressed, :copy is the default;
	##                    For Alt or combinations, this is :link; and
	##                    With no modifier, this defaults to :move.
	##                 [P_FIRST_TIME?]: _true if this is the first
	##                    time the dragging notifier is called for
	##                    this drag operation. (This allows to setup caches).
	##                 The allow-drag notifier should return:
	##                 1) _true if P_TREE is a valid destination,
	##                    _false otherwise
	##                 2) Optionally a new P_DEFAULT_MOUSE.
	p_release_drag_notifier << handler.check_type(p_release_drag_notifier, .model)
	p_allow_drag_notifier << _if (p_allow_drag_notifier _is _unset)
				 _then >> _proc @ok () >> _true _endproc
				 _else >> handler.check_type(p_allow_drag_notifier, .model)    
				 _endif
	p_agent.int!add_drag_to_agent(_self, p_release_drag_notifier, p_allow_drag_notifier)
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.config_change()
        ## An event handler for a window config_change event.
	## This check if we really changed size, and if so, it invokes
	## the resized() method on the window and returns the result:
	## _true if this will cause a damaged event,
	## _false otherwise
	_local l_window << .window, l_result << _false 
	_if ((l_window.height <> .int!cached_height) _orif (l_window.width <> .int!cached_width))
	_then
		l_result << _super.config_change()
		# may be we have just changed size again, store latest data...
		.int!cached_width << l_window.width
		.int!cached_height << l_window.height
	_endif
	>> l_result
_endmethod
$

_pragma(classify_level=advanced, usage={external})
_method tree_agent.editor_required_notifier
	## A handler that is called when the
	## end-user has pressed :f2 or clicked on a :value.
	## This should return an instantiated editor with its
	## properties set fine to start editing P_VALUE_ID fo P_TREE.
	## If nothing is returned, the value will not be edited.
	## When invoked, the handler gets passed four arguments:
	## P_TREE: Display tree that has been clicked on (unset
	##    if it is in the column headings or below
	##    the last one)
	## P_ROW_INDEX: Index in the list of visible
	##    display trees.
	## P_VALUE_ID: Id following :value in the styled string,
	##    identifying the value that we want to edit.
	## P_AGENT: Tree agent (self) that should be made the agent of
	## any editor that will be returned by this notifier.
	##
	## Note that if the windows-system does not allow in-place
	## editing, it does not make sense to ask for an
	## in-place-editor, and therefore this notifier will return
	## _unset in those case.
	>> _if !window_system!.int!canvas_is_container?
	   _then >> .editor_required_notifier
	   _endif
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.default_handle_expand(p_tree, p_row_index, p_event)
	##
	## Parameters    : P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised.
	##

	_local l_canvas << .window

	# Redraw
	# (It is not a problem to give an area that goes beyond the
	# visible area)
	_self.damaged( pixel_bounding_box.new_with_size( l_x << l_canvas.horizontal_position,
							 l_y << l_canvas.int!ypos_for(p_row_index),
							 l_x + l_canvas.width,
							 l_y + l_canvas.height ) )
	
	# Make sure the new trees are visible, as far down as necessary
	l_canvas.ensure_row_visibility( p_row_index, p_row_index + p_tree.int!nr_expanded_subtrees )  

	# We have done a redraw already, we do not want a complete
	# damaged event
	>> _false 
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.int!cancel_selection_change(p_event, p_agent)
	## Parameters    : P_EVENT: Event that has been raised.
	##                 P_AGENT: The agent that is handling events
	##                    for the window of P_EVENT.
	## Returns       : _true if the event has been handled, _false otherwise
	## Function      : Check by invoking :allow_dragging_notifier
	## 
	##
	# we're waiting for the corresponding mouse up event
	_if ((l_func << p_event.func) _is :release) _orif (l_func _is :double_release)
	_then
		.int!override_handler << _unset
	_endif
	>> _true 
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item}, usage={internal})
_method tree_agent.check_always_edit()
	## Parameters    : -
	## Returns       : -
	## Function      : If edit_always_on? is _true, and something
	##                 editable is selected, make sure that it is edited.
	##                 Otherwise, cancel the current editing, but
	##                 possibly recovering from pending input
	##                 errors if the current selection is appropriate.
	_if _self.edit_always_on? _andif (_not (l_selection << _self.selection).empty?) _andif
	    ((l_tree << l_selection.start_tree) _isnt _unset)
	_then
		# start editing the new selection
		_if _not _self.default_handle_edit(l_tree, l_selection.start_row, _unset, l_selection)
		_then
			# if we cannot edit the current selection, then at least stop
			# editing what is not selected anymore
			_self.stop_edit(_false, _false)
		_endif 
	_else
		# if we do not complete the current editing, allow recovery
		_self.stop_edit(_true, _false)
	_endif
_endmethod
$

_pragma(classify_level=restricted, usage={internal})
_method tree_agent.always_edit_handle_keypress(p_keyb_event)
	## Parameters    : P_KEYB_EVENT: An input event of category :keyboard.
	## Returns       : -
	## Function      : Implement special keyboard processing
	##                 behaviour that is appropriate for when
	##                 :edit_always_on? is _true, i.e. copy, cut,
	##                 paste behaviour and normal characters will
	##                 start editing (and overriding) the currently
	##                 edited value. 
	# check if we can do something ourselves with this keypress
	_local l_char << p_keyb_event.id, l_char? << l_char.is_class_of?(character)
	_if (p_keyb_event.modmask _is 2) 
	_then
		_if (l_char _is character.prop!name_to_char[:etx])
		_then
			# user pressed Ctrl-C
			_self.edit_manager.copy()
		_elif (l_char _is character.prop!name_to_char[:can])
		_then
			# user pressed Ctrl-X
			_self.edit_manager.cut(p_keyb_event)
		_elif (l_char _is character.prop!name_to_char[:syn])
		_then
			# user pressed Ctrl-V
			_self.edit_manager.paste(p_keyb_event)
		_elif (l_char _is character.prop!name_to_char[:soh])
		_then
			# user pressed Ctrl-A
			_self.edit_manager.set_focus(-1)
		_endif
	_elif l_char? _andif _not l_char.control?
	_then
		_self.edit_manager.set_focus(1, write_string(l_char), p_keyb_event)
	_elif (p_keyb_event.id _is :f2)
	_then
		_self.edit_manager.set_focus(-1)
	_endif
_endmethod
$

_pragma(classify_level=advanced, topic={tree_item}, usage={internal})
_method tree_agent.check_edit_position( _optional allow_recovery? )
        ##
	## Parameters    : - ALLOW_RECOVERY? - whether to allow editing
	## to continue if edit position is no longer valid. Defaults to
	## false. 
        ##
	## Returns       : -
	## Function      : If we are editing, check if the position of
	##                 the current in-place-editor is still ok.
	##                 If we are not editing, check if we should by
	##                 calling .check_always_edit()
        
	_if _self.editing?
	_then
		(l_tree, l_row, l_value_id) << _self.edit_manager.editing_value_info
                
		# check whether new position is still visible
		(l_found?, l_value_id, l_editor, l_text_style, l_val_left, l_val_right, l_column_no, l_column_end_no) <<
			.window.int!next_editable_value(l_tree, l_row, l_value_id, _self.editor_required_notifier, _false)
		_if l_found?
		_then
			(l_left, l_top, l_right, l_bottom) << .window.cell_info(l_tree, l_row,
                                                                                l_column_no, l_column_end_no)
                        
			(l_found?, l_left, l_top, l_right, l_bottom) << .window.check_bounds(l_left, l_top,
                                                                                             l_right, l_bottom)
			_if _not l_found?
			_then
                                _self.stop_edit( allow_recovery? _is _true, _false)
				_return
			_endif
			_self.edit_manager.check_edit_position(l_left, l_top, l_right, l_bottom, l_val_left, l_val_right)
		_else
			# If we can't find a value to edit then we can't allow recovery
                        _self.stop_edit( allow_recovery? _is _true, _false)
		_endif
	_else
		_self.check_always_edit()
	_endif
_endmethod
$

_pragma(classify_level=advanced)
_method tree_agent.edit_always_on? << p_new
	## If P_NEW is true, than when there is a selection, and this selection
	## contains an editable value, this will be in-place-edited immediately.
	## Focus will be retained by the canvas, or given to the in-place-editor
	## if the end-user clicked on the editable value.
	## If P_NEW is false, editing only starts when the end-user clicks in
	## the corresponding cell, or on the editable value, or presses F2.
	.edit_always_on? << p_new
	# now enable the callback of Alt-Down keystroke
	.window.enable_system_key_events()
	>> p_new
_endmethod
$

_pragma(classify_level=restricted)
_method tree_agent.handle_visibility_notification(visible?)
	##
	## The window visibility has changed.
	##

	_if _not visible?
	_then
		# Stop editing unless the window's top_frame exists and is visible
		tf << .window.top_frame
		_if _not (tf _isnt _unset _andif tf.realised? _andif tf.actual.is_mapped?)
		_then
			_self.stop_edit(_false,_false)
		_endif
	_else
		_if _not _self.editing?
		_then
			_self.check_always_edit()
		_endif
	_endif
_endmethod
$

_pragma(classify_level=restricted, usage={subclassable})
_method tree_agent.handle_text_release_click(p_tree, p_row_index, p_event, p_value, p_text_style, p_text, p_dx, p_dy, p_width, p_height)
	## Parameters    : P_TREE: Display tree that has been clicked on (unset
	##                    if it is in the column headings or below
	##                    the last one)
	##                 P_ROW_INDEX: Index in the list of visible
	##                    display trees.
	##                 P_EVENT: Event that has been raised
	##                 P_VALUE: _unset, or the :index in the
	##                    display_trees value if the text comes from a :value mark
	##                 P_TEXT_STYLE: Text styled used for depicting
	##                    a text, or :resolved_image in case P_TEXT concerned an image.
	##                 P_TEXT: The text as it is retrieved from P_TREE.value(P_VALUE)
	##                 P_DX, P_DY: Relative position in P_TEXT
	##                    (compared to P_TEXT top left being (0,0)
	##                 P_WIDTH, P_HEIGHT: Of the item that has been
	##                    clicked on.
	## Returns       : - 
	## Function      :
_endmethod
$

_pragma(classify_level=advanced, usage={internal})
_method tree_agent.sort_column( col_index )
	## 
	## Sorts the column with index COL_INDEX.

	.window.cursor << mouse_cursor.standard_cursor(:busy)
	_protect
		# check if the pre-sort notifier handles the sorting
		_if _self.notify( :pre_sort_notifier, col_index, .window ) _isnt _true
		_then
			# sort on this column
			_self.headings_holder.sort()
			# notify the sorting has been done
			_self.notify( :sort_notifier, col_index, .window )
		_endif
	_protection
		_self.set_default_cursor()
	_endprotect	
_endmethod
$

