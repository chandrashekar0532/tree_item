	#============================================================================== 
	# Folder-like Icon Schemes
	#============================================================================== 
	string_styles_holder.add_image_scheme(:folder,           :expanded,  :open_folder,
					                         :collapsed, :closed_folder,
					                         :default,   :closed_folder)
	#============================================================================== 
	# Database/collection Icon Schemes
	#============================================================================== 
