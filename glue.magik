_package sw

# ----------
# Add information for !current_locale!, this should be read from the
# OS, really
# ----------
_block
	!current_locale![:styled_string_colon] << ": "
	!current_locale![:styled_string_sep] << ", "
	!current_locale![:unset_value] << ""
_endblock
$

# ----------
# Default screen control colours, this should be read from the
# OS, really
# ----------
_block
	colour.called(:foreground)            << colour.called(:black)
	colour.called(:background)            << colour.called(:white)
	colour.called(:highlight)             << colour.called(:navy)
	colour.called(:highlight_text)        << colour.called(:white)
	colour.called(:stripes)               << colour.called(:navajowhite)
	colour.called(:button_face)           << colour.called(:lightgrey)
	colour.called(:button_shadow)         << colour.called(:gray)
	colour.called(:button_highlight)      << colour.called(:white)
	colour.called(:button_text)           << colour.called(:black)
	colour.called(:application_workspace) << colour.called(:button_shadow)
	colour.called(:window_workspace)      << colour.called(:button_face)
_endblock
$

# ----------
# Default text styles to be used by anyone
# ----------
_block
	_local l_default_style << text_style.new(colour.called(:foreground), text_style.font)
	# ToDo: Should actually be done on windows system initialise; font used is font.new_usage("default")
	string_styles_holder.add_text_style(:default, string_styles_holder.default_style << l_default_style)
	# For now, the only fonts used are plain, bold, fancy and fixed, since those are supported PS fonts as well
	# Otherwise, doc_default and doc_heading would have been useful in some occasions
	# Add some common style for general use
	string_styles_holder.add_text_style(:normal,     :foreground,    _false, font.new_logical("plain", 12))
	string_styles_holder.add_text_style(:strong,     # defined as bold, for now
	string_styles_holder.add_text_style(:bold,       :foreground,    _false, font.new_logical("bold",  12)))
	string_styles_holder.add_text_style(:inserted,   :green,         _false, font.new_logical("bold", 12))
	string_styles_holder.add_text_style(:inserted_m, :foreground,    _false, font.new_logical("bold", 12))
	string_styles_holder.add_text_style(:deleted,    :maroon,        _false, _unset, _false, _true)
	string_styles_holder.add_text_style(:deleted_m,  :foreground,    _false, _unset, _false, _true)
	string_styles_holder.add_text_style(:emphasis,   # defined as italic, for now
	string_styles_holder.add_text_style(:italic,     :foreground,    _false, font.new_logical("fancy", 12)))
	string_styles_holder.add_text_style(:error,      :red,           _false, font.new_logical("bold",  12))
	string_styles_holder.add_text_style(:disabled,   :button_shadow, _false)
	# Add some standard HTML styles
	string_styles_holder.add_text_style(:hyperlink,  :blue,          _true,  _unset, _true)
	string_styles_holder.add_text_style(:used_hyperlink, :purple,    _true,  _unset, _true)
	string_styles_holder.add_text_style(:typewriter, # symnonym for code
	string_styles_holder.add_text_style(:code,       :foreground,    _false, font.new_logical("fixed", 12)))
	string_styles_holder.add_text_style(:heading_1,  :foreground,    _false, font.new_logical("bold",  24))
	string_styles_holder.add_text_style(:heading_2,  :foreground,    _false, font.new_logical("bold",  18))
	string_styles_holder.add_text_style(:heading_3,  :foreground,    _false, font.new_logical("bold",  14))
	string_styles_holder.add_text_style(:heading_4,  :foreground,    _false, font.new_logical("bold",  12))
	string_styles_holder.add_text_style(:heading_5,  :foreground,    _false, font.new_logical("bold",  10))
	string_styles_holder.add_text_style(:heading_6,  :foreground,    _false, font.new_logical("bold",   8))
_endblock
$

